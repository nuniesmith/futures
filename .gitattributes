# =============================================================================
# Futures Trading Platform — Git Attributes
# =============================================================================
# Model files (.pt, .onnx) are generated by the trainer service
# (lib.training.trainer_server) and gitignored locally.
# The rb repo (github.com/nuniesmith/rb) is a service-only repo
# that pulls the nuniesmith/futures-trainer image from DockerHub.

# --- Ensure consistent line endings for source files ---
*.py text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.sh text eol=lf
*.txt text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
