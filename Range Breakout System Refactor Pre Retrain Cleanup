        BreakoutType,
        RangeConfig,
        BreakoutResult,
        detect_range_breakout,
        DEFAULT_CONFIGS,
    )

    config = DEFAULT_CONFIGS[BreakoutType.IB]
    result = detect_range_breakout(bars_1m, symbol="MES=F", config=config)
    if result.breakout_detected:
        print(result.direction, result.trigger_price)
