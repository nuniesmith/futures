def detect_ib_breakout(
    bars: pd.DataFrame,
    symbol: str,
    ib_high: float | None = None,
    ib_low: float | None = None,
    config: RangeConfig | None = None,
) -> BreakoutResult:
    """Shortcut: detect an Initial Balance breakout."""
