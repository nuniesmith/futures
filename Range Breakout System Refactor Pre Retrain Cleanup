            "breakout_bar_time": self.breakout_bar_time,
            "long_trigger": round(self.long_trigger, 4),
            "short_trigger": round(self.short_trigger, 4),
            "range_complete": self.range_complete,
            "range_bar_count": self.range_bar_count,
