// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © nuniesmith
//
// Ruby Futures Metrics v1.0
//
// Companion indicator for Ruby Futures — displays live metrics from Python
// docker services in a small dashboard table overlay.
//
// Purpose:
//   - Show live risk state, daily P&L, position info, regime, and signal quality
//   - Designed to be toggled ON for testing / verification, OFF while live trading
//   - All metrics data comes from manual inputs or request.seed() from GitHub
//   - NO trade execution — informational only
//
// Architecture:
//   Ruby Futures (main indicator) — chart signals, levels, TP lines
//   Ruby Futures Metrics (this)   — dashboard table, risk tracking, position info
//   Python Web UI                 — full dashboard (primary metrics source)
//
// Usage:
//   Add to chart alongside Ruby Futures. Toggle visibility as needed.
//   Update inputs manually or let request.seed() pull from engine.

//@version=6
indicator("Ruby Futures Metrics", overlay = true, max_labels_count = 50)

// ==================================================================================
// 🔧 CONTRACT SETTINGS (must match Ruby Futures main indicator)
// ==================================================================================
var group_contract = "🔧 Contract"

contract_type = input.string("MGC", title = "Contract",
     options = ["MGC","MES","MNQ","MYM","M2K","6E","6B","6J","MBT","MET","Custom"],
     group = group_contract)
account_size = input.float(50000, title = "Account Size ($)", group = group_contract, minval = 1000)
risk_pct     = input.float(1.0,   title = "Risk % Per Trade",  group = group_contract, minval = 0.1, maxval = 10, step = 0.1)

custom_point_value = input.float(10.0, title = "Custom: Point Value ($)", group = group_contract)

f_point_value(ct) =>
    switch ct
        "MGC" => 10.0
        "MES" => 5.0
        "MNQ" => 2.0
        "MYM" => 0.50
        "M2K" => 10.0
        "6E"  => 125000.0
        "6B"  => 62500.0
        "6J"  => 12500000.0
        "MBT" => 5.0
        "MET" => 50.0
        => custom_point_value

f_full_ratio(ct) =>
    switch ct
        "MGC" => 10.0
        "MES" => 5.0
        "MNQ" => 5.0
        "MYM" => 5.0
        "M2K" => 5.0
        "6E"  => 1.0
        "6B"  => 1.0
        "6J"  => 1.0
        "MBT" => 5.0
        "MET" => 5.0
        => 10.0

f_full_symbol(ct) =>
    switch ct
        "MGC" => "GC"
        "MES" => "ES"
        "MNQ" => "NQ"
        "MYM" => "YM"
        "M2K" => "RTY"
        "6E"  => "6E"
        "6B"  => "6B"
        "6J"  => "6J"
        "MBT" => "BTC"
        "MET" => "ETH"
        => "FULL"

CT_PVAL    = f_point_value(contract_type)
CT_FRATIO  = f_full_ratio(contract_type)
CT_FSYMBOL = f_full_symbol(contract_type)

safeDivide(numerator, denominator, defaultValue) =>
    denominator == 0 or na(denominator) ? defaultValue : numerator / denominator

// ==================================================================================
// 📊 DASHBOARD SETTINGS
// ==================================================================================
var group_dash = "📊 Dashboard"

dashboard_position = input.string("top_right", title = "Position",
     options = ["top_right","top_left","bottom_right","bottom_left"], group = group_dash)
color_theme        = input.string("dark", title = "Theme",
     options = ["dark","light"], group = group_dash)
show_engine_panel  = input.bool(true,  title = "Engine Signal Panel",    group = group_dash)
show_risk_panel    = input.bool(true,  title = "Risk / Position Panel",  group = group_dash)
show_trend_panel   = input.bool(true,  title = "Trend / Signal Panel",   group = group_dash)
show_regime_panel  = input.bool(true,  title = "Market Regime Panel",    group = group_dash)
show_breakout_panel = input.bool(true, title = "Breakout Levels Panel",  group = group_dash)
show_vol_panel     = input.bool(true,  title = "Volatility Panel",       group = group_dash)

// ==================================================================================
// 🔴 ENGINE SIGNAL STATE (from Python engine — manual or seed)
// ==================================================================================
var group_engine = "🔴 Engine Signal"

engine_auto_mode = input.bool(false, title = "Auto-Load from GitHub", group = group_engine,
     tooltip = "Read engine signal state from GitHub seed repo.\nMirrors the setting in Ruby Futures main indicator.")
engine_seed_repo = input.string("nuniesmith/futures-signals", title = "GitHub Repo", group = group_engine)
engine_seed_asset = input.string("auto", title = "Seed Asset",  group = group_engine,
     options = ["auto","gold","sp500","nasdaq","russell_2000","dow_jones","crude_oil","natural_gas","silver","copper","euro_fx","british_pound","japanese_yen","bitcoin","ethereum"])
engine_seed_expiry_h = input.float(4.0, title = "Signal Expiry (hours)", group = group_engine, minval = 0.5, maxval = 24, step = 0.5)

engine_active  = input.bool(false,   title = "Signal Active",       group = group_engine)
engine_dir     = input.string("LONG",title = "Direction",            group = group_engine, options = ["LONG","SHORT"])
engine_type    = input.string("ORB", title = "Breakout Type",        group = group_engine,
     options = ["ORB","PDR","IB","CONS","SWING","WEEKLY","MONTHLY","ASIAN","BBSQZ"])
engine_session = input.string("US",  title = "Session",              group = group_engine,
     options = ["US","LONDON","LONDON_NY","FRANKFURT","CME","CME_SETTLE","SYDNEY","TOKYO","SHANGHAI"])
engine_entry   = input.float(0.0,    title = "Entry Price",          group = group_engine)
engine_sl      = input.float(0.0,    title = "Stop Loss",            group = group_engine)
engine_tp1     = input.float(0.0,    title = "TP1",                  group = group_engine)
engine_tp2     = input.float(0.0,    title = "TP2",                  group = group_engine)
engine_tp3     = input.float(0.0,    title = "TP3",                  group = group_engine)
engine_cnn     = input.float(0.0,    title = "CNN Probability",      group = group_engine, minval = 0, maxval = 1, step = 0.01)
engine_quality = input.float(0.0,    title = "Signal Quality (0-1)", group = group_engine, minval = 0, maxval = 1, step = 0.01)
engine_mtf     = input.float(0.0,    title = "MTF Score (0-1)",      group = group_engine, minval = 0, maxval = 1, step = 0.01)
engine_bias    = input.string("NEUTRAL", title = "Daily Bias",       group = group_engine, options = ["LONG","SHORT","NEUTRAL"])

// ==================================================================================
// 📍 LIVE POSITION (from Tradovate via Python services)
// ==================================================================================
var group_pos = "📍 Live Position"

pos_active       = input.bool(false,      title = "In Position",         group = group_pos)
pos_dir          = input.string("LONG",   title = "Direction",           group = group_pos, options = ["LONG","SHORT"])
pos_entry        = input.float(0.0,       title = "Entry Price",         group = group_pos)
pos_contracts    = input.int(1,           title = "Micro Contracts",     group = group_pos, minval = 1)
pos_phase        = input.string("INITIAL",title = "Bracket Phase",       group = group_pos,
     options = ["INITIAL","TP1_HIT","TP2_HIT","TRAILING","CLOSED"])
pos_daily_pnl    = input.float(0.0,       title = "Daily Realised P&L ($)", group = group_pos)
pos_trades_today = input.int(0,           title = "Trades Today",           group = group_pos)
pos_consec_loss  = input.int(0,           title = "Consecutive Losses",     group = group_pos)

// ==================================================================================
// 🛡️ RISK LIMITS (from Python risk manager)
// ==================================================================================
var group_risk = "🛡️ Risk Limits"

tpt_mode    = input.bool(false, title = "TPT Mode (position limits)", group = group_risk)
tpt_account = input.string("$50K", title = "TPT Account Size",
     options = ["$50K","$100K","$150K"], group = group_risk)
daily_loss_limit_pct = input.float(4.0, title = "Daily Loss Limit %", group = group_risk, minval = 1, maxval = 10, step = 0.5)
max_consec_losses    = input.int(3,     title = "Max Consecutive Losses", group = group_risk, minval = 1, maxval = 10)
risk_blocked         = input.bool(false, title = "Risk Blocked (from engine)", group = group_risk)
risk_block_reason    = input.string("", title = "Block Reason", group = group_risk)

f_tpt_max() =>
    switch tpt_account
        "$50K"  => 2
        "$100K" => 3
        "$150K" => 4
        => 2

// ==================================================================================
// SEED DATA — read engine signal state from GitHub if auto mode is on
// ==================================================================================
f_contract_to_seed(ct) =>
    switch ct
        "MGC" => "gold"
        "MES" => "sp500"
        "MNQ" => "nasdaq"
        "MYM" => "dow_jones"
        "M2K" => "russell_2000"
        "6E"  => "euro_fx"
        "6B"  => "british_pound"
        "6J"  => "japanese_yen"
        "MBT" => "bitcoin"
        "MET" => "ethereum"
        => "gold"

_seed_asset = engine_seed_asset == "auto" ? f_contract_to_seed(contract_type) : engine_seed_asset
_seed_sym   = "seed/" + _seed_asset

// Read fields from seed
_sd_entry_raw = request.seed(engine_seed_repo, _seed_sym, open,   ignore_invalid_symbol = true)
_sd_stop_raw  = request.seed(engine_seed_repo, _seed_sym, high,   ignore_invalid_symbol = true)
_sd_tp1_raw   = request.seed(engine_seed_repo, _seed_sym, low,    ignore_invalid_symbol = true)
_sd_tp2_raw   = request.seed(engine_seed_repo, _seed_sym, close,  ignore_invalid_symbol = true)
_sd_vol_raw   = request.seed(engine_seed_repo, _seed_sym, volume, ignore_invalid_symbol = true)
_sd_time_raw  = request.seed(engine_seed_repo, _seed_sym, time,   ignore_invalid_symbol = true)

// Decode packed volume
_sd_vol_int  = int(math.round(nz(_sd_vol_raw, 0)))
_sd_dir_code = math.floor(_sd_vol_int / 1000000)
_sd_cnn_raw  = math.floor((_sd_vol_int % 1000000) / 100)
_sd_cnn_prob = _sd_cnn_raw / 10000.0

_sd_entry = nz(_sd_entry_raw, 0.0)
_sd_stop  = nz(_sd_stop_raw,  0.0)
_sd_tp1   = nz(_sd_tp1_raw,   0.0)
_sd_tp2   = nz(_sd_tp2_raw,   0.0)

// Expiry check
_sd_age_ms    = nz(_sd_time_raw, 0) > 0 ? (timenow - nz(_sd_time_raw, 0)) : 0
_sd_expiry_ms = engine_seed_expiry_h * 60 * 60 * 1000
_sd_expired   = _sd_age_ms > _sd_expiry_ms or _sd_age_ms <= 0
_sd_valid     = not na(_sd_entry_raw) and _sd_entry > 0 and _sd_stop > 0 and not _sd_expired and _sd_dir_code >= 1 and _sd_dir_code <= 2

_use_seed = engine_auto_mode and _sd_valid

// Effective engine signal values
eff_active = _use_seed ? true                               : engine_active
eff_dir    = _use_seed ? (_sd_dir_code == 1 ? "LONG" : "SHORT") : engine_dir
eff_entry  = _use_seed ? _sd_entry                          : engine_entry
eff_sl     = _use_seed ? _sd_stop                           : engine_sl
eff_tp1    = _use_seed ? (_sd_tp1 > 0 ? _sd_tp1 : 0.0)     : engine_tp1
eff_tp2    = _use_seed ? (_sd_tp2 > 0 ? _sd_tp2 : 0.0)     : engine_tp2
eff_cnn    = _use_seed ? _sd_cnn_prob                       : engine_cnn

// ==================================================================================
// MARKET COMPUTATIONS (lightweight — just what the dashboard needs)
// ==================================================================================
atr_14     = nz(ta.atr(14), 0.00001)
rsi_14     = ta.rsi(close, 14)
volatility = nz(ta.atr(14), 0.00001)

// Simple vol percentile
var array<float> vol_arr = array.new_float(200, volatility)
if barstate.isconfirmed
    array.push(vol_arr, volatility)
    if array.size(vol_arr) > 200
        array.shift(vol_arr)

vol_percentile = 0.5
if array.size(vol_arr) > 1
    count = 0
    for i = 0 to array.size(vol_arr) - 1
        if array.get(vol_arr, i) < volatility
            count += 1
    vol_percentile := count / array.size(vol_arr)

vol_regime = vol_percentile < 0.2 ? "VERY LOW" : vol_percentile < 0.4 ? "LOW" : vol_percentile >= 0.8 ? "VERY HIGH" : vol_percentile >= 0.6 ? "HIGH" : "MEDIUM"

// Regime detection (simplified)
higher_tf_ma = request.security(syminfo.tickerid, "60", ta.sma(close, 50), lookahead = barmerge.lookahead_off)
ma_200       = ta.sma(close, 200)
ma_slope     = (ma_200 - nz(ma_200[20], ma_200)) / 20
avg_slope    = ta.sma(math.abs(ta.change(ma_200)), 100)
norm_slope   = avg_slope == 0 ? 0 : ma_slope / avg_slope
returns_std  = ta.stdev(ta.change(close) / nz(close[1], close), 100)
returns_sma  = ta.sma(returns_std, 50)
norm_vol     = returns_sma == 0 ? 1 : returns_std / returns_sma

market_regime = norm_slope > 1.0 ? "TRENDING BULL" : norm_slope < -1.0 ? "TRENDING BEAR" : norm_vol > 1.5 ? "VOLATILE" : norm_vol < 0.8 ? "RANGING" : "NEUTRAL"

// Trend speed (simplified — just direction)
fastMA = ta.sma(hl2, 5)
slowMA = ta.sma(hl2, 34)
AO     = fastMA - slowMA

trendspeed_dir = AO > 0 ? "↗️" : AO < 0 ? "↘️" : "↔️"

// ORB / IB status (simplified detection matching Ruby Futures)
var group_session = "🕒 Session"
session_type      = input.string("Custom", title = "Session Type", options = ["US", "London", "Asia", "Custom"], group = group_session)
use_session_filter = input.bool(false, title = "Use Session Filter", group = group_session)
custom_start_hour  = input.int(9, minval = 0, maxval = 23, title = "Start Hour", group = group_session)
custom_end_hour    = input.int(16, minval = 0, maxval = 23, title = "End Hour", group = group_session)

var int start_hour = 0
var int end_hour   = 0
if session_type == "US"
    start_hour := 9
    end_hour   := 16
else if session_type == "London"
    start_hour := 8
    end_hour   := 16
else if session_type == "Asia"
    start_hour := 1
    end_hour   := 7
else
    start_hour := custom_start_hour
    end_hour   := custom_end_hour

in_session = (hour >= start_hour and hour <= end_hour) or not use_session_filter
bool session_started = in_session and not in_session[1] and barstate.isconfirmed

// ORB tracking
var float orb_high     = na
var float orb_low      = na
var int   orb_bars     = 0
var bool  orb_complete = false

if session_started
    orb_high     := high
    orb_low      := low
    orb_bars     := 0
    orb_complete := false

if not orb_complete and in_session
    orb_bars += 1
    orb_high := math.max(nz(orb_high, high), high)
    orb_low  := math.min(nz(orb_low, low), low)
    if orb_bars >= 30 and barstate.isconfirmed
        orb_complete := true

orb_breakout_up = orb_complete and close > orb_high and close[1] <= orb_high
orb_breakout_dn = orb_complete and close < orb_low  and close[1] >= orb_low

// IB tracking
var float ib_high     = na
var float ib_low      = na
var int   ib_bars     = 0
var bool  ib_complete = false

if session_started
    ib_high     := high
    ib_low      := low
    ib_bars     := 0
    ib_complete := false

if not ib_complete and in_session
    ib_bars += 1
    ib_high := math.max(nz(ib_high, high), high)
    ib_low  := math.min(nz(ib_low, low), low)
    if ib_bars >= 60 and barstate.isconfirmed
        ib_complete := true

ib_breakout_up = ib_complete and close > ib_high and close[1] <= ib_high
ib_breakout_dn = ib_complete and close < ib_low  and close[1] >= ib_low

// Squeeze detection
sq_basis = ta.sma(close, 20)
sq_dev   = 2.0 * ta.stdev(close, 20)
sq_bb_u  = sq_basis + sq_dev
sq_bb_l  = sq_basis - sq_dev
sq_kc_ma = ta.sma(close, 20)
sq_kc_r  = ta.atr(20)
sq_kc_u  = sq_kc_ma + sq_kc_r * 1.5
sq_kc_l  = sq_kc_ma - sq_kc_r * 1.5
squeeze_on    = sq_bb_l > sq_kc_l and sq_bb_u < sq_kc_u
squeeze_off   = sq_bb_l <= sq_kc_l and sq_bb_u >= sq_kc_u
squeeze_fired = squeeze_off and squeeze_on[1]

// Breakout strength (simplified)
vol_surge     = volume / nz(ta.sma(volume, 20), volume)
breakout_str  = math.min(vol_surge / 2.0, 1.0) * 50 + (squeeze_fired ? 25.0 : squeeze_on ? 15.0 : 0.0) + (norm_slope > 0.5 or norm_slope < -0.5 ? 25.0 : 10.0)

// Prev day range position
var float pd_high = na
var float pd_low  = na
if ta.change(dayofweek) != 0 and barstate.isconfirmed
    pd_high := high[1]
    pd_low  := low[1]
else
    pd_high := nz(pd_high, high)
    pd_low  := nz(pd_low,  low)

pd_pct = safeDivide(close - pd_low, pd_high - pd_low, 0.5) * 100

// ==================================================================================
// 📊 DASHBOARD TABLE
// ==================================================================================
if barstate.islast
    dash_pos   = dashboard_position == "top_right" ? position.top_right : dashboard_position == "top_left" ? position.top_left : dashboard_position == "bottom_right" ? position.bottom_right : position.bottom_left
    bg_color   = color_theme == "dark" ? color.rgb(0,0,0,85)    : color.rgb(255,255,255,85)
    text_color = color_theme == "dark" ? color.white             : color.black
    header_bg  = color_theme == "dark" ? color.rgb(40,40,40)     : color.rgb(200,200,200)
    label_col  = color_theme == "dark" ? color.silver             : color.gray
    up_c   = color.green
    dn_c   = color.red
    neu_c  = color.silver

    // Count rows needed (header + panels)
    var table dash = table.new(dash_pos, 4, 50, bgcolor = bg_color, border_width = 1, border_color = color.gray, frame_color = color.gray)
    table.clear(dash, 0, 0, 3, 49)

    // ── HEADER
    _src_tag = _use_seed ? " ● SEED" : ""
    table.cell(dash, 0, 0, "RUBY METRICS  " + contract_type + _src_tag, bgcolor = header_bg, text_color = _use_seed ? color.new(#00e676, 0) : text_color, text_halign = text.align_center, text_size = size.small)
    table.merge_cells(dash, 0, 0, 3, 0)
    int row = 1

    // ── ENGINE SIGNAL PANEL
    if show_engine_panel
        eng_bg = eff_active ? (eff_dir == "LONG" ? color.rgb(0,35,15) : color.rgb(35,0,10)) : color.rgb(18,18,18)
        dir_c  = eff_dir == "LONG" ? up_c : dn_c
        cnn_c  = eff_cnn >= 0.85 ? color.lime : eff_cnn >= 0.75 ? color.orange : dn_c
        qual_c = engine_quality >= 0.7 ? color.lime : engine_quality >= 0.5 ? color.orange : dn_c
        mtf_c  = engine_mtf >= 0.6 ? color.lime : engine_mtf >= 0.4 ? color.orange : dn_c
        bias_c = engine_bias == "LONG" ? up_c : engine_bias == "SHORT" ? dn_c : neu_c

        table.cell(dash, 0, row, "ENGINE", bgcolor = header_bg, text_color = text_color, text_halign = text.align_center, text_size = size.small)
        table.merge_cells(dash, 0, row, 3, row)
        row += 1

        // Status
        status_txt = eff_active ? eff_dir + "  " + engine_type : "— IDLE —"
        table.cell(dash, 0, row, eff_active ? "🔴" : "⚫", bgcolor = eng_bg, text_color = eff_active ? dir_c : neu_c, text_size = size.small)
        table.cell(dash, 1, row, status_txt,                  bgcolor = eng_bg, text_color = eff_active ? dir_c : neu_c, text_size = size.small)
        table.cell(dash, 2, row, "Sess:",                     bgcolor = eng_bg, text_color = label_col, text_size = size.small)
        table.cell(dash, 3, row, engine_session,              bgcolor = eng_bg, text_color = text_color, text_size = size.small)
        row += 1

        if eff_active and eff_entry > 0
            _risk_pts = math.abs(eff_entry - eff_sl)
            _risk_usd = _risk_pts * CT_PVAL
            _cts_micro = _risk_usd > 0 ? math.max(1, math.round((account_size * risk_pct / 100) / _risk_usd)) : 1

            table.cell(dash, 0, row, "Entry:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 1, row, str.tostring(eff_entry, "#.##"), bgcolor=eng_bg, text_color=dir_c, text_size=size.small)
            table.cell(dash, 2, row, "SL:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 3, row, str.tostring(eff_sl, "#.##") + "  -$" + str.tostring(math.round(_risk_usd * _cts_micro, 0)), bgcolor=eng_bg, text_color=dn_c, text_size=size.small)
            row += 1

            if eff_tp1 > 0
                _tp1_usd = math.abs(eff_tp1 - eff_entry) * CT_PVAL * _cts_micro
                table.cell(dash, 0, row, "TP1:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
                table.cell(dash, 1, row, str.tostring(eff_tp1, "#.##") + "  +$" + str.tostring(math.round(_tp1_usd, 0)), bgcolor=eng_bg, text_color=up_c, text_size=size.small)
                if eff_tp2 > 0
                    _tp2_usd = math.abs(eff_tp2 - eff_entry) * CT_PVAL * _cts_micro
                    table.cell(dash, 2, row, "TP2:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
                    table.cell(dash, 3, row, str.tostring(eff_tp2, "#.##") + "  +$" + str.tostring(math.round(_tp2_usd, 0)), bgcolor=eng_bg, text_color=up_c, text_size=size.small)
                else
                    table.cell(dash, 2, row, "", bgcolor=eng_bg, text_size=size.small)
                    table.cell(dash, 3, row, "", bgcolor=eng_bg, text_size=size.small)
                row += 1

            // Sizing
            _cts_full = math.max(1, math.round(_cts_micro / CT_FRATIO))
            table.cell(dash, 0, row, "Size:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 1, row, str.tostring(_cts_micro) + "× " + contract_type, bgcolor=eng_bg, text_color=text_color, text_size=size.small)
            table.cell(dash, 2, row, "Full:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 3, row, str.tostring(_cts_full) + "× " + CT_FSYMBOL, bgcolor=eng_bg, text_color=color.new(text_color, 30), text_size=size.small)
            row += 1

        // CNN + Quality + MTF + Bias
        table.cell(dash, 0, row, "CNN:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, str.tostring(math.round(eff_cnn * 100, 1)) + "%", bgcolor=eng_bg, text_color=cnn_c, text_size=size.small)
        table.cell(dash, 2, row, "Q:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(math.round(engine_quality * 100, 0)) + "%", bgcolor=eng_bg, text_color=qual_c, text_size=size.small)
        row += 1

        table.cell(dash, 0, row, "MTF:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, str.tostring(math.round(engine_mtf * 100, 0)) + "%", bgcolor=eng_bg, text_color=mtf_c, text_size=size.small)
        table.cell(dash, 2, row, "Bias:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, engine_bias, bgcolor=eng_bg, text_color=bias_c, text_size=size.small)
        row += 1

        // Seed status
        if engine_auto_mode
            _seed_status = _sd_valid ? "✅ LIVE" : (_sd_expired ? "⏰ EXPRD" : "❌ NONE")
            _seed_age    = _sd_age_ms > 0 ? str.tostring(math.round(_sd_age_ms / 60000, 0)) + "m" : "—"
            _seed_col    = _sd_valid ? color.new(#00e676, 0) : color.new(#ff1744, 0)
            table.cell(dash, 0, row, "Seed:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 1, row, _seed_status, bgcolor=eng_bg, text_color=_seed_col, text_size=size.small)
            table.cell(dash, 2, row, "Age:", bgcolor=eng_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 3, row, _seed_age, bgcolor=eng_bg, text_color=text_color, text_size=size.small)
            row += 1

    // ── RISK / POSITION PANEL
    if show_risk_panel
        table.cell(dash, 0, row, "RISK / POSITION", bgcolor = header_bg, text_color = text_color, text_halign = text.align_center, text_size = size.small)
        table.merge_cells(dash, 0, row, 3, row)
        row += 1

        pnl_c    = pos_daily_pnl >= 0 ? up_c : dn_c
        pnl_pct  = safeDivide(pos_daily_pnl, account_size, 0) * 100
        loss_pct = safeDivide(math.abs(math.min(pos_daily_pnl, 0)), account_size, 0) * 100
        loss_c   = loss_pct >= daily_loss_limit_pct ? dn_c : loss_pct >= daily_loss_limit_pct * 0.5 ? color.orange : up_c
        closs_c  = pos_consec_loss >= max_consec_losses ? dn_c : pos_consec_loss >= max_consec_losses - 1 ? color.orange : up_c
        max_pos  = tpt_mode ? f_tpt_max() : 5

        // Daily P&L
        table.cell(dash, 0, row, "P&L:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, (pos_daily_pnl >= 0 ? "+$" : "-$") + str.tostring(math.abs(math.round(pos_daily_pnl, 0))), bgcolor=bg_color, text_color=pnl_c, text_size=size.small)
        table.cell(dash, 2, row, "P&L%:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(math.round(pnl_pct, 2)) + "%", bgcolor=bg_color, text_color=pnl_c, text_size=size.small)
        row += 1

        // Trades + max
        table.cell(dash, 0, row, "Trades:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, str.tostring(pos_trades_today), bgcolor=bg_color, text_color=text_color, text_size=size.small)
        table.cell(dash, 2, row, "Max:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(max_pos) + (tpt_mode ? " TPT" : ""), bgcolor=bg_color, text_color=text_color, text_size=size.small)
        row += 1

        // Loss % + consecutive
        table.cell(dash, 0, row, "Loss%:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, str.tostring(math.round(loss_pct, 2)) + "%", bgcolor=bg_color, text_color=loss_c, text_size=size.small)
        table.cell(dash, 2, row, "C.Loss:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(pos_consec_loss), bgcolor=bg_color, text_color=closs_c, text_size=size.small)
        row += 1

        // Risk blocked warning
        if risk_blocked
            table.cell(dash, 0, row, "⛔ BLOCKED", bgcolor=color.rgb(50,0,0), text_color=dn_c, text_halign=text.align_center, text_size=size.small)
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 2, row, str.length(risk_block_reason) > 0 ? risk_block_reason : "Risk limit hit", bgcolor=color.rgb(50,0,0), text_color=color.orange, text_size=size.small)
            table.merge_cells(dash, 2, row, 3, row)
            row += 1

        // Live position
        if pos_active and pos_entry > 0
            pos_pts = pos_dir == "LONG" ? close - pos_entry : pos_entry - close
            pos_usd = pos_pts * CT_PVAL * pos_contracts
            pos_c   = pos_usd >= 0 ? up_c : dn_c
            pos_r   = safeDivide(pos_usd, account_size * risk_pct / 100, 0)
            pos_bg  = color.rgb(0, 28, 10)

            table.cell(dash, 0, row, "LIVE " + pos_dir, bgcolor=pos_bg, text_color=pos_c, text_halign=text.align_center, text_size=size.small)
            table.merge_cells(dash, 0, row, 1, row)
            table.cell(dash, 2, row, pos_phase, bgcolor=pos_bg, text_color=text_color, text_size=size.small)
            table.merge_cells(dash, 2, row, 3, row)
            row += 1

            table.cell(dash, 0, row, "Entry:", bgcolor=pos_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 1, row, str.tostring(pos_entry, "#.##"), bgcolor=pos_bg, text_color=text_color, text_size=size.small)
            table.cell(dash, 2, row, "Unrl:", bgcolor=pos_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 3, row, (pos_usd >= 0 ? "+$" : "-$") + str.tostring(math.abs(math.round(pos_usd, 0))), bgcolor=pos_bg, text_color=pos_c, text_size=size.small)
            row += 1

            table.cell(dash, 0, row, "Cts:", bgcolor=pos_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 1, row, str.tostring(pos_contracts) + "× " + contract_type, bgcolor=pos_bg, text_color=text_color, text_size=size.small)
            table.cell(dash, 2, row, "R:", bgcolor=pos_bg, text_color=label_col, text_size=size.small)
            table.cell(dash, 3, row, str.tostring(math.round(pos_r, 2)) + "R", bgcolor=pos_bg, text_color=pos_c, text_size=size.small)
            row += 1

    // ── TREND / SIGNAL PANEL
    if show_trend_panel
        table.cell(dash, 0, row, "TREND", bgcolor = header_bg, text_color = text_color, text_halign = text.align_center, text_size = size.small)
        table.merge_cells(dash, 0, row, 3, row)
        row += 1

        table.cell(dash, 0, row, "Dir:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, trendspeed_dir, bgcolor=bg_color, text_color=AO > 0 ? up_c : AO < 0 ? dn_c : neu_c, text_size=size.small)
        table.cell(dash, 2, row, "Sess:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, in_session ? "ON" : "OFF", bgcolor=bg_color, text_color=in_session ? up_c : dn_c, text_size=size.small)
        row += 1

    // ── MARKET REGIME PANEL
    if show_regime_panel
        table.cell(dash, 0, row, "REGIME", bgcolor = header_bg, text_color = text_color, text_halign = text.align_center, text_size = size.small)
        table.merge_cells(dash, 0, row, 3, row)
        row += 1

        regime_emoji = market_regime == "TRENDING BULL" ? "🐂" : market_regime == "TRENDING BEAR" ? "🐻" : market_regime == "VOLATILE" ? "⚡" : market_regime == "RANGING" ? "↔️" : "⚖️"
        regime_col   = market_regime == "TRENDING BULL" ? up_c : market_regime == "TRENDING BEAR" ? dn_c : market_regime == "VOLATILE" ? color.orange : neu_c

        table.cell(dash, 0, row, regime_emoji, bgcolor=bg_color, text_color=regime_col, text_size=size.small)
        table.cell(dash, 1, row, market_regime, bgcolor=bg_color, text_color=regime_col, text_size=size.small)
        table.cell(dash, 2, row, "RSI:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(math.round(rsi_14, 0)), bgcolor=bg_color, text_color=rsi_14 > 60 ? up_c : rsi_14 < 40 ? dn_c : neu_c, text_size=size.small)
        row += 1

    // ── BREAKOUT LEVELS PANEL
    if show_breakout_panel
        table.cell(dash, 0, row, "BREAKOUTS", bgcolor = header_bg, text_color = text_color, text_halign = text.align_center, text_size = size.small)
        table.merge_cells(dash, 0, row, 3, row)
        row += 1

        orb_status = orb_breakout_up ? "🚀" : orb_breakout_dn ? "📉" : orb_complete ? "✓" : "⏳"
        ib_status  = ib_breakout_up  ? "🚀" : ib_breakout_dn  ? "📉" : ib_complete  ? "✓" : "⏳"
        table.cell(dash, 0, row, "ORB:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, orb_status, bgcolor=bg_color, text_color=orb_breakout_up ? up_c : orb_breakout_dn ? dn_c : orb_complete ? color.orange : neu_c, text_size=size.small)
        table.cell(dash, 2, row, "IB:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, ib_status, bgcolor=bg_color, text_color=ib_breakout_up ? up_c : ib_breakout_dn ? dn_c : ib_complete ? color.orange : neu_c, text_size=size.small)
        row += 1

        sqz_status = squeeze_on ? "💥" : squeeze_fired ? "🔥" : "〰️"
        table.cell(dash, 0, row, "Sqz:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, sqz_status, bgcolor=bg_color, text_color=squeeze_on ? color.yellow : squeeze_fired ? up_c : neu_c, text_size=size.small)
        table.cell(dash, 2, row, "PD%:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(math.round(pd_pct, 0)) + "%", bgcolor=bg_color, text_color=pd_pct > 60 ? up_c : pd_pct < 40 ? dn_c : neu_c, text_size=size.small)
        row += 1

        str_col   = breakout_str >= 70 ? up_c : breakout_str >= 40 ? color.orange : dn_c
        str_emoji = breakout_str >= 70 ? "🔥" : breakout_str >= 40 ? "〰️" : "❄️"
        _atr_usd  = math.round(atr_14 * CT_PVAL)
        table.cell(dash, 0, row, "Str:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, str.tostring(math.round(breakout_str, 0)) + "%  " + str_emoji, bgcolor=bg_color, text_color=str_col, text_size=size.small)
        table.cell(dash, 2, row, "ATR$:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, "$" + str.tostring(_atr_usd) + "/ct", bgcolor=bg_color, text_color=text_color, text_size=size.small)
        row += 1

    // ── VOLATILITY PANEL
    if show_vol_panel
        table.cell(dash, 0, row, "VOL", bgcolor = header_bg, text_color = text_color, text_halign = text.align_center, text_size = size.small)
        table.merge_cells(dash, 0, row, 3, row)
        row += 1

        table.cell(dash, 0, row, "ATR:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 1, row, str.tostring(math.round(atr_14, 5)), bgcolor=bg_color, text_color=text_color, text_size=size.small)
        table.cell(dash, 2, row, "%ile:", bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, str.tostring(math.round(vol_percentile * 100, 0)) + "%", bgcolor=bg_color, text_color=text_color, text_size=size.small)
        row += 1

        vol_emoji = vol_regime == "VERY HIGH" ? "⚡⚡" : vol_regime == "HIGH" ? "⚡" : vol_regime == "VERY LOW" ? "🧘🧘" : vol_regime == "LOW" ? "🧘" : "〰️"
        vol_strat = vol_percentile > 0.8 ? "AVOID" : vol_percentile < 0.2 ? "BRKOUT" : vol_percentile > 0.6 ? "WIDE" : vol_percentile < 0.4 ? "TIGHT" : "NORM"
        table.cell(dash, 0, row, vol_emoji, bgcolor=bg_color, text_color=vol_regime == "VERY HIGH" ? dn_c : vol_regime == "HIGH" ? color.orange : vol_regime == "VERY LOW" ? up_c : neu_c, text_size=size.small)
        table.cell(dash, 1, row, vol_strat, bgcolor=bg_color, text_color=vol_percentile > 0.8 ? dn_c : vol_percentile < 0.2 ? up_c : vol_percentile > 0.6 ? color.orange : color.new(up_c, 40), text_size=size.small)
        table.cell(dash, 2, row, vol_regime, bgcolor=bg_color, text_color=label_col, text_size=size.small)
        table.cell(dash, 3, row, "", bgcolor=bg_color, text_size=size.small)
        row += 1

// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © nuniesmith
//
// Ruby Futures v2.0
//
// Clean chart indicator for manual futures trading (TradingView + Tradovate).
// Designed to work alongside the Python engine web UI — no redundant dashboard.
//
// What this indicator does:
//   - Futures contract specs & position sizing (MGC, MES, MNQ, MYM, M2K, 6E, 6B, 6J, MBT, MET)
//   - Ruby wave / trend / regime / S&R / volatility signal detection
//   - TP1 + TP2 lines on every signal (configurable R:R, default 1:2)
//   - Entry / SL / TP labels with dollar values per contract
//   - Opening Range, Initial Balance, Prev Day, Asian Range levels
//   - Squeeze detection
//   - Engine signal overlay via request.seed() (auto) or manual inputs
//   - Lightweight — NO large dashboard table (use web UI for metrics)
//
// Companion metrics indicator: Ruby Futures Metrics (separate script)
//   - Connects to Python docker services for live risk, P&L, position data
//   - Open it when testing, close it while live trading

//@version=6
indicator("Ruby Futures", overlay = true, max_labels_count = 500, max_boxes_count = 500, max_lines_count = 500)

// ==================================================================================
// 🔧 FUTURES CONTRACT SETTINGS
// ==================================================================================
var group_futures = "🔧 Futures Contract"

contract_type = input.string("MGC", title = "Contract",
     options = ["MGC","MES","MNQ","MYM","M2K","6E","6B","6J","MBT","MET","Custom"],
     group = group_futures)
account_size   = input.float(50000, title = "Account Size ($)",     group = group_futures, minval = 1000)
risk_pct       = input.float(1.0,   title = "Risk % Per Trade",     group = group_futures, minval = 0.1, maxval = 10, step = 0.1)
show_full_size = input.bool(true,   title = "Show Micro + Full Side-by-Side", group = group_futures)
tpt_mode       = input.bool(false,  title = "TPT Mode (position limits)",     group = group_futures)
tpt_account    = input.string("$50K", title = "TPT Account Size",
     options = ["$50K","$100K","$150K"], group = group_futures)

custom_tick_size    = input.float(0.10,  title = "Custom: Tick Size",        group = group_futures)
custom_tick_value   = input.float(1.00,  title = "Custom: Tick Value ($)",   group = group_futures)
custom_point_value  = input.float(10.0,  title = "Custom: Point Value ($)",  group = group_futures)
custom_full_ratio   = input.float(10.0,  title = "Custom: Full/Micro ratio", group = group_futures)
custom_full_symbol  = input.string("FULL", title = "Custom: Full Symbol",    group = group_futures)

// ── Contract lookup helpers ────────────────────────────────────
f_tick_size(ct) =>
    switch ct
        "MGC" => 0.10
        "MES" => 0.25
        "MNQ" => 0.25
        "MYM" => 1.0
        "M2K" => 0.10
        "6E"  => 0.00005
        "6B"  => 0.0001
        "6J"  => 0.0000005
        "MBT" => 5.0
        "MET" => 0.01
        => custom_tick_size

f_tick_value(ct) =>
    switch ct
        "MGC" => 1.00
        "MES" => 1.25
        "MNQ" => 0.50
        "MYM" => 0.50
        "M2K" => 1.00
        "6E"  => 6.25
        "6B"  => 6.25
        "6J"  => 6.25
        "MBT" => 5.00
        "MET" => 1.00
        => custom_tick_value

f_point_value(ct) =>
    switch ct
        "MGC" => 10.0
        "MES" => 5.0
        "MNQ" => 2.0
        "MYM" => 0.50
        "M2K" => 10.0
        "6E"  => 125000.0
        "6B"  => 62500.0
        "6J"  => 12500000.0
        "MBT" => 5.0
        "MET" => 50.0
        => custom_point_value

f_full_ratio(ct) =>
    switch ct
        "MGC" => 10.0
        "MES" => 5.0
        "MNQ" => 5.0
        "MYM" => 5.0
        "M2K" => 5.0
        "6E"  => 1.0
        "6B"  => 1.0
        "6J"  => 1.0
        "MBT" => 5.0
        "MET" => 5.0
        => custom_full_ratio

f_full_symbol(ct) =>
    switch ct
        "MGC" => "GC"
        "MES" => "ES"
        "MNQ" => "NQ"
        "MYM" => "YM"
        "M2K" => "RTY"
        "6E"  => "6E"
        "6B"  => "6B"
        "6J"  => "6J"
        "MBT" => "BTC"
        "MET" => "ETH"
        => custom_full_symbol

CT_TICK     = f_tick_size(contract_type)
CT_TVAL     = f_tick_value(contract_type)
CT_PVAL     = f_point_value(contract_type)
CT_FRATIO   = f_full_ratio(contract_type)
CT_FSYMBOL  = f_full_symbol(contract_type)

f_tpt_max() =>
    switch tpt_account
        "$50K"  => 2
        "$100K" => 3
        "$150K" => 4
        => 2

f_calc_contracts(entry_price, sl_price) =>
    risk_dollars      = account_size * (risk_pct / 100)
    sl_points         = math.abs(entry_price - sl_price)
    risk_per_contract = sl_points * CT_PVAL
    risk_per_contract <= 0 ? 1 : math.max(1, math.round(risk_dollars / risk_per_contract))

f_move_dollars(price_a, price_b, contracts) =>
    math.abs(price_a - price_b) * CT_PVAL * contracts

// ==================================================================================
// 🔴 ENGINE SIGNAL OVERLAY
// AUTO mode: reads signals from GitHub via request.seed() — zero manual work
// MANUAL mode: populate from engine output via Settings panel
// ==================================================================================
var group_engine = "🔴 Engine Signal Overlay"

engine_auto_mode = input.bool(false, title = "Auto-Load from GitHub (request.seed)", group = group_engine,
     tooltip = "When ON, reads engine signals from GitHub repo.\nRequires the repo to be registered as a Pine seed source.\nWhen OFF, use the manual input fields below.")
engine_seed_repo = input.string("nuniesmith/futures-signals", title = "GitHub Repo", group = group_engine,
     tooltip = "GitHub user/repo for request.seed(). Must match engine's GITHUB_SIGNALS_REPO.")
engine_seed_asset = input.string("auto", title = "Seed Asset Filter", group = group_engine,
     options = ["auto","gold","sp500","nasdaq","russell_2000","dow_jones","crude_oil","natural_gas","silver","copper","euro_fx","british_pound","japanese_yen","bitcoin","ethereum"],
     tooltip = "Which asset's seed file to read. 'auto' maps from Contract Type.")
engine_seed_expiry_h = input.float(4.0, title = "Signal Expiry (hours)", group = group_engine,
     minval = 0.5, maxval = 24, step = 0.5)

engine_active    = input.bool(false,   title = "Signal Active (manual)",      group = group_engine)
engine_dir       = input.string("LONG",title = "Direction (manual)",          group = group_engine, options = ["LONG","SHORT"])
engine_entry     = input.float(0.0,    title = "Entry Price (manual)",        group = group_engine)
engine_sl        = input.float(0.0,    title = "Stop Loss (manual)",          group = group_engine)
engine_tp1       = input.float(0.0,    title = "TP1 (manual)",               group = group_engine)
engine_tp2       = input.float(0.0,    title = "TP2 (manual)",               group = group_engine)
engine_tp3       = input.float(0.0,    title = "TP3 (manual)",               group = group_engine)
engine_cnn       = input.float(0.0,    title = "CNN Probability (manual)",    group = group_engine, minval = 0, maxval = 1, step = 0.01)

// ==================================================================================
// 📈 CORE ANALYSIS INPUTS
// ==================================================================================
var group_trend_speed = "⚡ Trend Speed"
asset_type          = input.string('Gold', title = 'Asset Type', options = ['Gold', 'Crypto', 'Stocks', 'Forex'], group = group_trend_speed)
max_length          = input.int(20, minval = 1, title = 'Maximum Length', group = group_trend_speed)
accel_multiplier    = input.float(0.02, minval = 0.01, step = 0.01, title = 'Accelerator Multiplier', group = group_trend_speed)
lookback_period     = input.int(200, minval = 1, title = 'Lookback Period', group = group_trend_speed)
min_wave_ratio      = input.float(1.5, minval = 0.1, step = 0.1, title = 'Minimum Wave Ratio', group = group_trend_speed)
exit_momentum_threshold = input.float(0.7, minval = 0.1, maxval = 1.0, step = 0.1, title = 'Exit Momentum Threshold', group = group_trend_speed)
collen              = input.int(100, minval = 5, title = 'Collection Period', group = group_trend_speed)

var group_trend_colors = "🎨 Trend Colors"
up_hist_col         = input.color(#82ffc3, title = 'Trend Up', group = group_trend_colors)
up_hist_col_bright  = input.color(color.lime, title = 'Trend Up Strong', group = group_trend_colors)
dn_hist_col         = input.color(color.red, title = 'Trend Down', group = group_trend_colors)
dn_hist_col_bright  = input.color(#f78c8c, title = 'Trend Down Strong', group = group_trend_colors)

var group_patterns = "🔍 Patterns"
length              = input.int(200, title = "S/R Range Length", group = group_patterns)
signal_sensitivity  = input.float(0.5, minval = 0.1, maxval = 2.0, step = 0.1, title = "Signal Sensitivity", group = group_patterns)

var group_sentiment_trend = "📉 Sentiment"
fastperiod          = input.int(5, title = "AO Fast Period", minval = 2, group = group_sentiment_trend)
slowperiod          = input.int(34, title = "AO Slow Period", minval = 5, group = group_sentiment_trend)
signalperiod        = input.int(7, title = "AO Signal Period", minval = 2, group = group_sentiment_trend)
use_ao_zero         = input.bool(true, title = "Use AO Zero Cross", group = group_sentiment_trend)
use_ao_signal       = input.bool(true, title = "Use AO Signal Cross", group = group_sentiment_trend)
use_regime_filter   = input.bool(true, title = "Use Market Regime", group = group_sentiment_trend)
regime_ma_length    = input.int(200, minval = 20, title = "Regime MA Length", group = group_sentiment_trend)
regime_std_length   = input.int(100, minval = 20, title = "Regime Vol Lookback", group = group_sentiment_trend)
regime_threshold    = input.float(1.0, minval = 0.1, maxval = 2.0, step = 0.1, title = "Regime Threshold", group = group_sentiment_trend)
use_multi_timeframe = input.bool(true, title = "Multi-TF Filter", group = group_sentiment_trend)
higher_tf           = input.string("60", title = "Higher TF", options = ["15", "30", "60", "120", "240", "D"], group = group_sentiment_trend)
momentum_lookback   = input.int(3, minval = 1, title = "Momentum Lookback", group = group_sentiment_trend)

var group_sr = "🛡️ S/R"
sr_lookback     = input.int(20, minval = 5, title = 'S/R Lookback', group = group_sr)
sr_threshold    = input.float(0.3, minval = 0.1, maxval = 1.0, step = 0.1, title = 'S/R Sensitivity', group = group_sr)
include_sr      = input.bool(true, title = 'Higher TF S/R', group = group_sr)

// ==================================================================================
// 🎨 VISUAL & SIGNAL SETTINGS
// ==================================================================================
var group_visual = "🎨 Visuals"
main_col            = input.color(color.blue, title = "Mid Band Color", group = group_visual)
green_color         = input.color(#00ffbb, title = "Bullish Color", group = group_visual)
red_color           = input.color(#ff1100, title = "Bearish Color", group = group_visual)
heat_sensative      = input.int(70, minval = 10, title = "Heatmap Sensitivity", group = group_visual)
clean_chart_mode    = input.bool(false, title = "Clean Chart (hide bands)", group = group_visual)
show_potential_signals = input.bool(true, title = "Show Potential Signals", group = group_visual)
show_entry_labels   = input.bool(true, title = "Show Signal Labels", group = group_visual)
show_entry_zones    = input.bool(true, title = "Show Entry Zones", group = group_visual)
show_atr_bands      = input.bool(false, title = "ATR Bands", group = group_visual)
show_engine_lines   = input.bool(true, title = "Engine Entry/SL/TP Lines", group = group_visual)
show_cnn_badge      = input.bool(true, title = "Engine CNN Badge", group = group_visual)

var group_tp = "🎯 Take Profit"
tp1_rr              = input.float(1.0, title = "TP1 Risk:Reward", group = group_tp, minval = 0.5, maxval = 10, step = 0.5,
     tooltip = "TP1 = Entry ± (SL distance × this value). Default 1:1.")
tp2_rr              = input.float(2.0, title = "TP2 Risk:Reward", group = group_tp, minval = 1.0, maxval = 20, step = 0.5,
     tooltip = "TP2 = Entry ± (SL distance × this value). Default 1:2.")
show_tp_lines       = input.bool(true, title = "Draw TP Lines on Signals", group = group_tp)
tp_line_length      = input.int(40, title = "TP Line Length (bars)", group = group_tp, minval = 10, maxval = 200)

var group_time_settings = "⏰ Time"
start_date          = input.time(timestamp('1 Jan 2020'), "Start Date", group = group_time_settings)
timer_option        = input.string('From start', title = 'Timer Option', options = ['Custom', 'From start'], group = group_time_settings)

var group_session = "🕒 Session"
session_type        = input.string("Custom", title = "Session Type", options = ["US", "London", "Asia", "Custom"], group = group_session)
use_session_filter  = input.bool(false, title = "Use Session Filter", group = group_session)
custom_start_hour   = input.int(9, minval = 0, maxval = 23, title = "Start Hour", group = group_session)
custom_end_hour     = input.int(16, minval = 0, maxval = 23, title = "End Hour", group = group_session)

var group_volatility = "🌡️ Volatility"
atr_len                   = input.int(14, minval = 1, title = "ATR Length", group = group_volatility)
volatility_history        = input.int(200, minval = 20, title = "History Length", group = group_volatility)
use_kmeans_atr            = input.bool(true, title = "K-Means Adaptive ATR", group = group_volatility)
training_data_period      = input.int(250, minval = 50, title = "Training Period", group = group_volatility)
recalculate_clusters      = input.int(50, minval = 1, title = "Recalc Every N Bars", group = group_volatility)
highvol                   = input.float(0.8, minval = 0.5, maxval = 1.0, step = 0.1, title = "High Vol Centroid", group = group_volatility)
midvol                    = input.float(0.5, minval = 0.3, maxval = 0.8, step = 0.1, title = "Mid Vol Centroid", group = group_volatility)
lowvol                    = input.float(0.2, minval = 0.1, maxval = 0.5, step = 0.1, title = "Low Vol Centroid", group = group_volatility)
max_iterations            = input.int(10, minval = 3, maxval = 50, title = "K-Means Iterations", group = group_volatility)
require_atr_minimum       = input.bool(true, title = "Require Min Vol", group = group_volatility)
min_volatility_percentile = input.float(0.2, minval = 0.0, maxval = 0.5, step = 0.05, title = "Min Vol %ile", group = group_volatility)
avoid_high_volatility     = input.bool(true, title = "Avoid Extreme Vol", group = group_volatility)
max_volatility_percentile = input.float(0.9, minval = 0.5, maxval = 1.0, step = 0.05, title = "Max Vol %ile", group = group_volatility)

var group_signal = "🚨 Signal"
signal_quality_threshold = input.float(0.6, minval = 0.1, maxval = 1.0, step = 0.05, title = "Quality Threshold", group = group_signal)
signal_cooldown          = input.int(5, minval = 1, title = "Bars Between Signals", group = group_signal)
require_trend_alignment  = input.bool(true, title = "Require Trend Alignment", group = group_signal)
volume_filter            = input.bool(false, title = "Volume Filter", group = group_signal)
min_volume_threshold     = input.float(1.2, minval = 0.5, maxval = 3.0, step = 0.1, title = "Min Volume Threshold", group = group_signal)

var group_breakout = "📍 Breakout Levels"
show_orb      = input.bool(true, title = "ORB (30-min)",           group = group_breakout)
show_prev_day = input.bool(true, title = "Prev Day High/Low/Mid",  group = group_breakout)
show_ib       = input.bool(true, title = "Initial Balance (60-min)",group = group_breakout)
show_squeeze  = input.bool(true, title = "Squeeze Detection",      group = group_breakout)
show_asian_range = input.bool(true, title = "Asian Range Box",      group = group_breakout)
orb_length    = input.int(30, minval = 5,  title = "ORB Minutes",  group = group_breakout)
ib_length     = input.int(60, minval = 30, title = "IB Minutes",   group = group_breakout)
squeeze_bb_length = input.int(20, minval = 5,   title = "Squeeze BB Length",      group = group_breakout)
squeeze_bb_mult   = input.float(2.0, minval = 0.5, title = "Squeeze BB Mult",     group = group_breakout)
squeeze_kc_length = input.int(20, minval = 5,   title = "Squeeze KC Length",      group = group_breakout)
squeeze_kc_mult   = input.float(1.5, minval = 0.5, title = "Squeeze KC Mult",     group = group_breakout)

// ==================================================================================
// SESSION MANAGEMENT
// ==================================================================================
var int start_hour = 0
var int end_hour   = 0
if session_type == "US"
    start_hour := 9
    end_hour   := 16
else if session_type == "London"
    start_hour := 8
    end_hour   := 16
else if session_type == "Asia"
    start_hour := 1
    end_hour   := 7
else
    start_hour := custom_start_hour
    end_hour   := custom_end_hour

in_session = (hour >= start_hour and hour <= end_hour) or not use_session_filter

bool session_started = in_session and not in_session[1] and barstate.isconfirmed
bool session_ended   = not in_session and in_session[1] and barstate.isconfirmed

// ==================================================================================
// UTILITY FUNCTIONS
// ==================================================================================
safeDivide(numerator, denominator, defaultValue) =>
    denominator == 0 or na(denominator) ? defaultValue : numerator / denominator

StartTime() =>
    timer_option == "Custom" ? time > start_date : true

calc_accel_factor(float counts_diff, float prev_counts_diff) =>
    delta_counts_diff = math.abs(counts_diff - prev_counts_diff)
    float max_delta = ta.highest(delta_counts_diff, 200)
    max_delta := max_delta == 0 ? 1 : max_delta
    delta_counts_diff / max_delta

adjust_alpha(float dyn_length, float accel_factor, float accel_mult) =>
    alpha_base = 2 / (dyn_length + 1)
    alpha = alpha_base * (1 + accel_factor * accel_mult * 0.8)
    math.min(0.9, alpha)

f_detect_bullish_candle_pattern() =>
    body_size    = math.abs(close - open)
    candle_range = high - low == 0 ? 0.00001 : high - low
    lower_wick   = math.min(open, close) - low
    upper_wick   = high - math.max(open, close)
    hammer             = body_size < candle_range * 0.3 and lower_wick > body_size * 2 and upper_wick < body_size
    bullish_engulfing  = close > open and close[1] < open[1] and close > open[1] and open < close[1]
    pin_bar            = lower_wick > candle_range * 0.6 and body_size < candle_range * 0.3 and upper_wick < candle_range * 0.3
    hammer or bullish_engulfing or pin_bar

f_detect_bearish_candle_pattern() =>
    body_size    = math.abs(close - open)
    candle_range = high - low == 0 ? 0.00001 : high - low
    lower_wick   = math.min(open, close) - low
    upper_wick   = high - math.max(open, close)
    shooting_star     = body_size < candle_range * 0.3 and upper_wick > body_size * 2 and lower_wick < body_size
    bearish_engulfing = close < open and close[1] > open[1] and close < open[1] and open > close[1]
    pin_bar           = upper_wick > candle_range * 0.6 and body_size < candle_range * 0.3 and lower_wick < candle_range * 0.3
    shooting_star or bearish_engulfing or pin_bar

swing_atr_val           = ta.atr(14)
high_highest_len_minus1 = ta.highest(high, sr_lookback - 1)
high_lowest_len_times2  = ta.lowest(high, sr_lookback * 2)
low_lowest_len_minus1   = ta.lowest(low, sr_lookback - 1)
low_highest_len_times2  = ta.highest(low, sr_lookback * 2)

findSwingHighs(src, len, thresh, highest_val, lowest_val, atr_val) =>
    var array<float> pivots = array.new_float()
    if array.size(pivots) > 10
        array.shift(pivots)
    isHigh = src[len] > src[len+1] and src[len] > src[len-1] and src[len] > highest_val and (src[len] - lowest_val) / atr_val > thresh
    if isHigh
        array.unshift(pivots, src[len])
    pivots

findSwingLows(src, len, thresh, lowest_val, highest_val, atr_val) =>
    var array<float> pivots = array.new_float()
    if array.size(pivots) > 10
        array.shift(pivots)
    isLow = src[len] < src[len+1] and src[len] < src[len-1] and src[len] < lowest_val and (highest_val - src[len]) / atr_val > thresh
    if isLow
        array.unshift(pivots, src[len])
    pivots

getNearestLevel(price, levels) =>
    float nearest = na
    min_dist = 10000000.0
    if array.size(levels) > 0
        for i = 0 to math.min(array.size(levels) - 1, 5)
            lvl  = array.get(levels, i)
            dist = math.abs(price - lvl)
            if dist < min_dist
                min_dist := dist
                nearest  := lvl
    nearest

getNearestSR(tf) =>
    ph = request.security(syminfo.tickerid, tf, ta.pivothigh(high, sr_lookback, sr_lookback), lookahead = barmerge.lookahead_off)
    pl = request.security(syminfo.tickerid, tf, ta.pivotlow (low,  sr_lookback, sr_lookback), lookahead = barmerge.lookahead_off)
    [ph, pl]

// ==================================================================================
// TREND SPEED + WAVE ANALYSIS
// ==================================================================================
var int   max_length_eff       = 20
var float accel_multiplier_eff = 0.02
var int   lookback_period_eff  = 200

if barstate.isfirst
    switch asset_type
        "Crypto" =>
            max_length_eff       := 20
            accel_multiplier_eff := 0.03
            lookback_period_eff  := 100
        "Gold" =>
            max_length_eff       := 20
            accel_multiplier_eff := 0.015
            lookback_period_eff  := 200
        "Stocks" =>
            max_length_eff       := 20
            accel_multiplier_eff := 0.01
            lookback_period_eff  := 150
        "Forex" =>
            max_length_eff       := 20
            accel_multiplier_eff := 0.02
            lookback_period_eff  := 150

counts_diff = close
max_abs     = ta.highest(math.abs(counts_diff), 200)
counts_norm = safeDivide(counts_diff + max_abs, 2 * max_abs, 0.5)
dyn_length  = 5 + counts_norm * (max_length_eff - 5)
accel_factor = calc_accel_factor(counts_diff, nz(counts_diff[1]))
alpha        = adjust_alpha(dyn_length, accel_factor, accel_multiplier_eff)

var float dyn_ema = na
dyn_ema := na(dyn_ema[1]) ? close : alpha * close + (1 - alpha) * dyn_ema[1]

type TrendData
    array<float> change
    array<int>   t

var bullish = TrendData.new(array.new<float>(), array.new<int>())
var bearish = TrendData.new(array.new<float>(), array.new<int>())
var int   x1    = na
var float y1    = na
var int   pos   = 0
var float speed = 0.0
c = ta.rma(close, 10)
o = ta.rma(open, 10)

if na(x1) and StartTime()
    x1 := bar_index
    y1 := o

speed_lowest  = ta.lowest(speed,  math.max(1, bar_index - nz(x1, bar_index)))
speed_highest = ta.highest(speed, math.max(1, bar_index - nz(x1, bar_index)))

if StartTime()
    if close > dyn_ema and close[1] <= dyn_ema
        bearish.change.unshift(speed_lowest)
        bearish.t.unshift(bar_index - x1)
        x1    := bar_index
        y1    := close
        pos   := 1
        speed := c - o
    if close < dyn_ema and close[1] >= dyn_ema
        bullish.change.unshift(speed_highest)
        bullish.t.unshift(bar_index - x1)
        x1    := bar_index
        y1    := close
        pos   := -1
        speed := c - o

speed      := speed + c - o
trendspeed  = ta.hma(speed, 5)

var float bull_max = 0.0001
var float bear_max = -0.0001
var float bull_avg = 0.0001
var float bear_avg = -0.0001
var float wave_size_ratio_avg  = 1.0
var float wave_size_ratio_max  = 1.0
var float current_ratio_avg    = 0.0
var float current_ratio_max    = 0.0
var string market_bias         = "Neutral"
var float dominance_avg_value  = 0.0

if barstate.isconfirmed
    bullish_recent = array.size(bullish.change) > 0 ? array.slice(bullish.change, 0, math.min(lookback_period_eff, array.size(bullish.change))) : array.new<float>()
    bearish_recent = array.size(bearish.change) > 0 ? array.slice(bearish.change, 0, math.min(lookback_period_eff, array.size(bearish.change))) : array.new<float>()
    bull_max := array.size(bullish_recent) > 0 ? array.max(bullish_recent) : 0.0001
    bear_max := array.size(bearish_recent) > 0 ? array.min(bearish_recent) : -0.0001
    bull_avg := array.size(bullish_recent) > 0 ? array.avg(bullish_recent) : 0.0001
    bear_avg := array.size(bearish_recent) > 0 ? array.avg(bearish_recent) : -0.0001
    wave_size_ratio_avg := safeDivide(bull_avg, math.abs(bear_avg), 1)
    wave_size_ratio_max := safeDivide(bull_max, math.abs(bear_max), 1)
    dominance_avg_value := bull_avg - math.abs(bear_avg)
    market_bias         := dominance_avg_value > 0 ? "Bullish" : dominance_avg_value < 0 ? "Bearish" : "Neutral"
    current_ratio_avg   := speed > 0 ? safeDivide(speed, bull_avg, 1) : safeDivide(speed, math.abs(bear_avg), -1)
    current_ratio_max   := speed > 0 ? safeDivide(speed, bull_max, 1) : safeDivide(speed, math.abs(bear_max), -1)

// ==================================================================================
// SUPPORT / RESISTANCE
// ==================================================================================
var float nearest_resistance_1m = na
var float nearest_support_1m    = na
var float nearest_resistance_5m = na
var float nearest_support_5m    = na

if include_sr
    [res1, sup1] = getNearestSR("1")
    [res5, sup5] = getNearestSR("5")
    nearest_resistance_1m := res1
    nearest_support_1m    := sup1
    nearest_resistance_5m := res5
    nearest_support_5m    := sup5

long_bias_1m  = include_sr and not na(nearest_support_1m)    and not na(nearest_resistance_1m) ? close > nearest_support_1m    and (nearest_resistance_1m - close > close - nearest_support_1m)    : false
short_bias_1m = include_sr and not na(nearest_support_1m)    and not na(nearest_resistance_1m) ? close < nearest_resistance_1m and (nearest_resistance_1m - close < close - nearest_support_1m)    : false
long_bias_5m  = include_sr and not na(nearest_support_5m)    and not na(nearest_resistance_5m) ? close > nearest_support_5m    and (nearest_resistance_5m - close > close - nearest_support_5m)    : false
short_bias_5m = include_sr and not na(nearest_support_5m)    and not na(nearest_resistance_5m) ? close < nearest_resistance_5m and (nearest_resistance_5m - close < close - nearest_support_5m)    : false

// ==================================================================================
// BREAKOUT LEVELS
// ==================================================================================

// Previous Day High / Low / Mid
var float prev_day_high = na
var float prev_day_low  = na
if ta.change(dayofweek) != 0 and barstate.isconfirmed
    prev_day_high := high[1]
    prev_day_low  := low[1]
else
    prev_day_high := nz(prev_day_high, high)
    prev_day_low  := nz(prev_day_low,  low)

prev_day_mid = (prev_day_high + prev_day_low) / 2

// 30-Min Opening Range
var float orb_high     = na
var float orb_low      = na
var int   orb_bars     = 0
var bool  orb_complete = false

if session_started
    orb_high     := high
    orb_low      := low
    orb_bars     := 0
    orb_complete := false

if not orb_complete and in_session
    orb_bars += 1
    orb_high := math.max(orb_high, high)
    orb_low  := math.min(orb_low,  low)
    if orb_bars >= orb_length and barstate.isconfirmed
        orb_complete := true

orb_breakout_up = orb_complete and close > orb_high and close[1] <= orb_high
orb_breakout_dn = orb_complete and close < orb_low  and close[1] >= orb_low

// Initial Balance 60-min
var float ib_high     = na
var float ib_low      = na
var int   ib_bars     = 0
var bool  ib_complete = false

if session_started
    ib_high     := high
    ib_low      := low
    ib_bars     := 0
    ib_complete := false

if not ib_complete and in_session
    ib_bars += 1
    ib_high := math.max(ib_high, high)
    ib_low  := math.min(ib_low,  low)
    if ib_bars >= ib_length and barstate.isconfirmed
        ib_complete := true

ib_breakout_up = ib_complete and close > ib_high and close[1] <= ib_high
ib_breakout_dn = ib_complete and close < ib_low  and close[1] >= ib_low

// Squeeze Detection
basis    = ta.sma(close, squeeze_bb_length)
dev      = squeeze_bb_mult * ta.stdev(close, squeeze_bb_length)
upper_bb = basis + dev
lower_bb = basis - dev
ma_kc    = ta.sma(close, squeeze_kc_length)
range_kc = ta.atr(squeeze_kc_length)
upper_kc = ma_kc + range_kc * squeeze_kc_mult
lower_kc = ma_kc - range_kc * squeeze_kc_mult
squeeze_on   = lower_bb > lower_kc and upper_bb < upper_kc
squeeze_off  = lower_bb <= lower_kc and upper_bb >= upper_kc
squeeze_fired = squeeze_off and squeeze_on[1]

// Asian Range box (19:00–02:00 ET)
in_asian = hour >= 19 or hour <= 2
var float asian_high     = na
var float asian_low      = na
var bool  asian_complete = false
var box   asian_box      = na

bool asian_start = in_asian and not in_asian[1]
bool asian_end   = not in_asian and in_asian[1]

if asian_start
    asian_high     := high
    asian_low      := low
    asian_complete := false

if in_asian and not asian_complete
    asian_high := math.max(nz(asian_high, high), high)
    asian_low  := math.min(nz(asian_low,  low),  low)

if asian_end and not na(asian_high) and not na(asian_low)
    asian_complete := true

if show_asian_range and asian_complete and barstate.islast
    if not na(asian_box)
        box.delete(asian_box)
    asian_box := box.new(bar_index - 200, asian_high, bar_index + 30, asian_low,
         bgcolor = color.new(#ff9800, 88), border_color = color.new(#ff9800, 50),
         border_width = 1, border_style = line.style_dashed)

// Breakout markers
plotshape(show_orb and orb_breakout_up, title="ORB Up",   style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime,0), size=size.small)
plotshape(show_orb and orb_breakout_dn, title="ORB Down", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,0),  size=size.small)
plotshape(show_ib  and ib_breakout_up,  title="IB Up",    style=shape.circle,       location=location.belowbar, color=color.new(color.aqua,0), size=size.tiny)
plotshape(show_ib  and ib_breakout_dn,  title="IB Down",  style=shape.circle,       location=location.abovebar, color=color.new(color.orange,0), size=size.tiny)
plotshape(show_squeeze and squeeze_fired, title="Squeeze", style=shape.diamond,     location=location.belowbar, color=color.new(color.yellow,0), size=size.small)

// Level plots
plot(show_orb  and orb_complete ? orb_high     : na, "ORB High",      color=color.new(color.green,50),  linewidth=1, style=plot.style_linebr)
plot(show_orb  and orb_complete ? orb_low      : na, "ORB Low",       color=color.new(color.red,50),    linewidth=1, style=plot.style_linebr)
plot(show_ib   and ib_complete  ? ib_high      : na, "IB High",       color=color.new(color.aqua,60),   linewidth=1, style=plot.style_linebr)
plot(show_ib   and ib_complete  ? ib_low       : na, "IB Low",        color=color.new(color.orange,60), linewidth=1, style=plot.style_linebr)
plot(show_prev_day              ? prev_day_high : na, "PD High",      color=color.new(color.blue,70),   linewidth=1, style=plot.style_stepline)
plot(show_prev_day              ? prev_day_low  : na, "PD Low",       color=color.new(color.purple,70), linewidth=1, style=plot.style_stepline)
plot(show_prev_day              ? prev_day_mid  : na, "PD Mid",       color=color.new(color.gray,80),   linewidth=1, style=plot.style_stepline)

// ==================================================================================
// VOLATILITY + ADAPTIVE ATR
// ==================================================================================
volatility = nz(ta.atr(atr_len), 0.00001)
volatility := volatility <= 0 ? 0.00001 : volatility
atr_14     = nz(ta.atr(14), volatility)

var float adaptive_atr  = volatility
var string vol_status   = "MEDIUM"
var int    cluster      = 1
var float  vol_multiplier = 1.0

vol_highest_training = ta.highest(volatility, training_data_period)
vol_lowest_training  = ta.lowest(volatility,  training_data_period)

if use_kmeans_atr and (bar_index % recalculate_clusters == 0 or bar_index == training_data_period) and barstate.isconfirmed
    upper     = nz(vol_highest_training, volatility * 1.5)
    lower     = nz(vol_lowest_training,  volatility * 0.5)
    atr_range = upper - lower <= 0 ? volatility : upper - lower
    hv_init   = lower + atr_range * highvol
    mv_init   = lower + atr_range * midvol
    lv_init   = lower + atr_range * lowvol
    var array<float> hv = array.new_float()
    var array<float> mv = array.new_float()
    var array<float> lv = array.new_float()
    var float a_mean = hv_init
    var float b_mean = mv_init
    var float c_mean = lv_init
    int  iters = 0
    bool cont  = true
    while cont and iters < max_iterations and bar_index >= training_data_period - 1
        array.clear(hv)
        array.clear(mv)
        array.clear(lv)

        for i = 0 to training_data_period - 1
            val = nz(volatility[i], volatility)
            d1 = math.abs(val - a_mean)
            d2 = math.abs(val - b_mean)
            d3 = math.abs(val - c_mean)
            if d1 <= d2 and d1 <= d3
                array.push(hv, val)
            else if d2 <= d1 and d2 <= d3
                array.push(mv, val)
            else
                array.push(lv, val)

        new_a = array.size(hv) > 0 ? array.avg(hv) : a_mean
        new_b = array.size(mv) > 0 ? array.avg(mv) : b_mean
        new_c = array.size(lv) > 0 ? array.avg(lv) : c_mean

        new_a := nz(new_a, hv_init)
        new_b := nz(new_b, mv_init)
        new_c := nz(new_c, lv_init)

        if math.abs(new_a - a_mean) < volatility * 0.001 and math.abs(new_b - b_mean) < volatility * 0.001 and math.abs(new_c - c_mean) < volatility * 0.001
            cont := false

        a_mean := new_a
        b_mean := new_b
        c_mean := new_c
        iters += 1
    dist_a   = math.abs(volatility - a_mean)
    dist_b   = math.abs(volatility - b_mean)
    dist_c   = math.abs(volatility - c_mean)
    cluster      := dist_a <= dist_b and dist_a <= dist_c ? 0 : dist_b <= dist_a and dist_b <= dist_c ? 1 : 2
    adaptive_atr := cluster == 0 ? a_mean : cluster == 1 ? b_mean : c_mean
    adaptive_atr := nz(adaptive_atr, volatility)
    vol_status   := cluster == 0 ? "HIGH" : cluster == 1 ? "MEDIUM" : "LOW"
    vol_multiplier := cluster == 0 ? 0.8 : cluster == 1 ? 1.0 : 1.2

var array<float> vol_array = array.new_float(volatility_history, volatility)
if barstate.isconfirmed
    array.push(vol_array, volatility)
    if array.size(vol_array) > volatility_history
        array.shift(vol_array)

vol_percentile = 0.5
if array.size(vol_array) > 1
    count = 0
    for i = 0 to array.size(vol_array) - 1
        if array.get(vol_array, i) < volatility
            count += 1
    vol_percentile := count / array.size(vol_array)

vol_within_range = not (require_atr_minimum and vol_percentile < min_volatility_percentile) and not (avoid_high_volatility and vol_percentile > max_volatility_percentile)

// ==================================================================================
// MARKET REGIME + PHASE
// ==================================================================================
higher_tf_ma  = request.security(syminfo.tickerid, higher_tf, ta.sma(close, 50), lookahead = barmerge.lookahead_off)
ma_cur        = ta.sma(close, regime_ma_length)
ma_slope      = (ma_cur - nz(ma_cur[20], ma_cur)) / 20
avg_slope_abs = ta.sma(math.abs(ta.change(ma_cur)), regime_std_length)
norm_slope    = avg_slope_abs == 0 ? 0 : ma_slope / avg_slope_abs
returns       = ta.change(close) / nz(close[1], close)
returns_stdev     = ta.stdev(returns, regime_std_length)
returns_stdev_sma = ta.sma(returns_stdev, 50)
norm_vol          = returns_stdev_sma == 0 ? 1 : returns_stdev / returns_stdev_sma
market_regime     = norm_slope > regime_threshold ? "TRENDING BULL" : norm_slope < -regime_threshold ? "TRENDING BEAR" : norm_vol > 1.5 ? "VOLATILE" : norm_vol < 0.8 ? "RANGING" : "NEUTRAL"

var string prev_regime = market_regime
regime_changed = market_regime != prev_regime and bar_index > 5
prev_regime   := market_regime

fastMA   = ta.sma(hl2, fastperiod)
slowMA   = ta.sma(hl2, slowperiod)
AO       = fastMA - slowMA
signalAO = ta.sma(AO, signalperiod)

var string market_phase = "ACCUMULATION"
var color  phase_color  = color.yellow

lowest_src  = ta.lowest(low,  length)
highest_src = ta.highest(high, length)
mid         = ta.hma(math.avg(lowest_src, highest_src), 15)

if ta.crossover(close, highest_src[10]) and AO > 0
    market_phase := "UPTREND"
    phase_color  := color.green

if ta.crossunder(close, lowest_src[10]) and AO < 0
    market_phase := "DOWNTREND"
    phase_color  := color.red

if close > highest_src[5] and close < highest_src and AO > 0 and AO < AO[10]
    market_phase := "DISTRIBUTION"
    phase_color  := color.orange

if close < lowest_src[5] and close > lowest_src and AO < 0 and AO > AO[10]
    market_phase := "ACCUMULATION"
    phase_color  := color.yellow

rsi_14       = ta.rsi(close, 14)
in_uptrend   = market_phase == "UPTREND"   or (market_phase == "ACCUMULATION" and AO > 0 and rsi_14 > 50)
in_downtrend = market_phase == "DOWNTREND" or (market_phase == "DISTRIBUTION" and AO < 0 and rsi_14 < 50)

// ==================================================================================
// SIGNAL QUALITY + FINAL SIGNALS
// ==================================================================================
rsi_value            = rsi_14
strong_trend_aligned = use_multi_timeframe ? (in_uptrend and close > higher_tf_ma) or (in_downtrend and close < higher_tf_ma) : true
vol_surge_raw      = volume / nz(ta.sma(volume, 20), volume)
vol_surge_score    = math.min(vol_surge_raw / 2.0, 1.0) * 30.0
wave_ratio_score   = math.min(math.abs(current_ratio_avg) / 3.0, 1.0) * 40.0
squeeze_score      = squeeze_fired ? 15.0 : squeeze_on ? 10.0 : 0.0
trend_align_score  = (in_uptrend or in_downtrend) and strong_trend_aligned ? 15.0 : (in_uptrend or in_downtrend) ? 7.5 : 0.0
breakout_strength  = math.round(wave_ratio_score + vol_surge_score + squeeze_score + trend_align_score, 1)
momentum_change     = ta.change(close, momentum_lookback) / nz(close[momentum_lookback], close)
momentum_stdev      = ta.stdev(momentum_change, 100)
normalized_velocity = momentum_stdev == 0 ? 0 : momentum_change / momentum_stdev
bullish_candle = f_detect_bullish_candle_pattern()
bearish_candle = f_detect_bearish_candle_pattern()
trend_speed_factor = math.abs(current_ratio_avg) > min_wave_ratio ? 1.0 : math.abs(current_ratio_avg) > min_wave_ratio * 0.7 ? 0.7 : math.abs(current_ratio_avg) > min_wave_ratio * 0.5 ? 0.4 : 0.0
htf_bias_factor    = include_sr ? (in_uptrend and (long_bias_1m or long_bias_5m) ? (long_bias_1m and long_bias_5m ? 1.0 : 0.5) : in_downtrend and (short_bias_1m or short_bias_5m) ? (short_bias_1m and short_bias_5m ? 1.0 : 0.5) : 0.0) : 0.0
squeeze_factor     = squeeze_fired ? 1.0 : squeeze_on ? 0.5 : 0.0
velocity_change    = ta.change(normalized_velocity, momentum_lookback)
signal_quality_score = 0.0

if in_uptrend
    signal_quality_score := ((vol_percentile > 0.2 and vol_percentile < 0.7 ? 1.5 : 0.5) + (normalized_velocity > 0 ? 1.0 : 0) + (velocity_change > 0 ? 0.5 : 0) + trend_speed_factor * 0.5 + htf_bias_factor * 0.5 + squeeze_factor * 0.5) / 4.5
else if in_downtrend
    signal_quality_score := ((vol_percentile > 0.2 and vol_percentile < 0.7 ? 1.5 : 0.5) + (normalized_velocity < 0 ? 1.0 : 0) + (velocity_change < 0 ? 0.5 : 0) + trend_speed_factor * 0.5 + htf_bias_factor * 0.5 + squeeze_factor * 0.5) / 4.5
else
    signal_quality_score := ((vol_percentile < 0.3 ? 1.5 : 0.5) + (math.abs(normalized_velocity) < 0.5 ? 1.0 : 0) + (math.abs(velocity_change) < 0.2 ? 0.5 : 0) + trend_speed_factor * 0.5 + htf_bias_factor * 0.5 + squeeze_factor * 0.5) / 4.5

high_quality = signal_quality_score >= signal_quality_threshold

lowest_20  = ta.lowest(low[1],  20)
lowest_30  = ta.lowest(low[1],  30)
highest_20 = ta.highest(high[1],20)
highest_30 = ta.highest(high[1],30)

bottom     = low  <= lowest_20  and low  > lowest_30
top        = high >= highest_20 and high < highest_30

volume_sma_20 = ta.sma(volume, 20)
volume_ok     = not volume_filter or volume > volume_sma_20 * min_volume_threshold

lowest_low_length   = ta.lowest(low,  length)
highest_high_length = ta.highest(high, length)

final_buy_raw  = (bottom or (lowest_low_length == low[1]   and close > open) or (squeeze_fired and close > open and in_uptrend))   and (in_uptrend   or not require_trend_alignment) and high_quality and volume_ok and vol_within_range and strong_trend_aligned and (math.abs(current_ratio_avg) >= min_wave_ratio * 0.7 or squeeze_fired)
final_sell_raw = (top    or (highest_high_length == high[1] and close < open) or (squeeze_fired and close < open and in_downtrend)) and (in_downtrend or not require_trend_alignment) and high_quality and volume_ok and vol_within_range and strong_trend_aligned and (math.abs(current_ratio_avg) >= min_wave_ratio * 0.7 or squeeze_fired)

var int last_buy  = 0
var int last_sell = 0
final_buy  = final_buy_raw  and (bar_index - last_buy  > signal_cooldown) and in_session
final_sell = final_sell_raw and (bar_index - last_sell > signal_cooldown) and in_session

if final_buy  then last_buy  := bar_index
if final_sell then last_sell := bar_index

sl_phase_mult  = market_phase == "UPTREND" or market_phase == "DOWNTREND" ? 1.5 : 1.2
sl_phase_mult *= use_regime_filter ? (market_regime == "TRENDING BULL" or market_regime == "TRENDING BEAR" ? 1.2 : market_regime == "VOLATILE" ? 1.5 : market_regime == "RANGING" ? 0.8 : 1.0) : 1.0

long_sl  = low  - volatility * vol_multiplier * sl_phase_mult
short_sl = high + volatility * vol_multiplier * sl_phase_mult

// ── Contract sizing for signals
ruby_buy_contracts  = final_buy  ? f_calc_contracts(close, long_sl)  : 1
ruby_sell_contracts = final_sell ? f_calc_contracts(close, short_sl) : 1

// ==================================================================================
// TP LEVELS FOR RUBY SIGNALS
// ==================================================================================
// Compute TP1 and TP2 based on configurable R:R from SL distance
// For buys:  TP = entry + (entry - SL) * RR
// For sells: TP = entry - (SL - entry) * RR

f_long_tp(entry, sl, rr) =>
    risk = math.abs(entry - sl)
    entry + risk * rr

f_short_tp(entry, sl, rr) =>
    risk = math.abs(sl - entry)
    entry - risk * rr

// ==================================================================================
// VISUALS — chart plots (heatmap, bands, S/R channels)
// ==================================================================================
regression_line_val = ta.sma(bar_index * ta.correlation(bar_index, hl2, length) * ta.stdev(hl2, length) / ta.stdev(bar_index, length) + ta.sma(hl2, length) - ta.sma(bar_index, length) * ta.correlation(bar_index, hl2, length) * ta.stdev(hl2, length) / ta.stdev(bar_index, length), length)
color_level         = (close - regression_line_val) / ta.stdev(close - regression_line_val, 200)
color_level        := math.max(math.min(color_level, 5), -5)
heatmap_color       = color_level > 0 ? color.from_gradient(color_level, 0, math.max(ta.highest(color_level, heat_sensative), 0.0001), color.yellow, color.red) : color.from_gradient(color_level, math.min(ta.lowest(color_level, heat_sensative), -0.0001), 0, color.aqua, color.yellow)

barcolor(heatmap_color)

plot(highest_src, "Resistance", color = clean_chart_mode ? na : red_color,   linewidth = 1)
plot(mid,         "Mid Band",   color = clean_chart_mode ? na : main_col,    linewidth = 1)
plot(lowest_src,  "Support",    color = clean_chart_mode ? na : green_color, linewidth = 1)

mid_price = ta.sma(close, 20)
plot(show_atr_bands ? mid_price + adaptive_atr : na, "ATR+1", color.new(color.blue, 70))
plot(show_atr_bands ? mid_price - adaptive_atr : na, "ATR-1", color.new(color.blue, 70))

// Signal arrows
plotshape(final_buy,  title="Buy",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.large)
plotshape(final_sell, title="Sell", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.large)

roc_3 = ta.roc(close, 3)
plotshape(show_potential_signals and low  <= lowest_src  + adaptive_atr * 0.5 and roc_3 < -signal_sensitivity, title="Pot Buy",  style=shape.diamond, location=location.belowbar, color=color.new(green_color,70), size=size.tiny)
plotshape(show_potential_signals and high >= highest_src - adaptive_atr * 0.5 and roc_3 >  signal_sensitivity, title="Pot Sell", style=shape.diamond, location=location.abovebar, color=color.new(red_color,70),   size=size.tiny)

// ==================================================================================
// SIGNAL LABELS WITH ENTRY / SL / TP1 / TP2 + DOLLAR VALUES
// ==================================================================================
if show_entry_labels
    if final_buy
        _sl       = long_sl
        _tp1      = f_long_tp(close, _sl, tp1_rr)
        _tp2      = f_long_tp(close, _sl, tp2_rr)
        _cts      = ruby_buy_contracts
        _cts_full = math.max(1, math.round(_cts / CT_FRATIO))
        _risk_usd = f_move_dollars(close, _sl, _cts)
        _tp1_usd  = f_move_dollars(_tp1, close, _cts)
        _tp2_usd  = f_move_dollars(_tp2, close, _cts)

        label.new(bar_index, low - atr_14,
             "BUY  " + contract_type + "\n" +
             "Entry: " + str.tostring(close, "#.##") + "\n" +
             "SL:    " + str.tostring(_sl, "#.##") + "  (-$" + str.tostring(math.round(_risk_usd, 0)) + ")\n" +
             "TP1:   " + str.tostring(_tp1, "#.##") + "  (+$" + str.tostring(math.round(_tp1_usd, 0)) + ")  " + str.tostring(tp1_rr, "#.#") + "R\n" +
             "TP2:   " + str.tostring(_tp2, "#.##") + "  (+$" + str.tostring(math.round(_tp2_usd, 0)) + ")  " + str.tostring(tp2_rr, "#.#") + "R\n" +
             str.tostring(_cts) + "× " + contract_type +
             (show_full_size ? "  /  " + str.tostring(_cts_full) + "× " + CT_FSYMBOL : "") + "\n" +
             "Q: " + str.tostring(math.round(signal_quality_score * 100, 0)) + "%  Wave: " + str.tostring(math.round(math.abs(current_ratio_avg), 2)) + "x",
             color=color.new(color.green,20), style=label.style_label_up, textcolor=color.black, size=size.normal)

        // Draw TP lines
        if show_tp_lines
            _rb = bar_index + tp_line_length
            line.new(bar_index, close, _rb, close, color=color.new(color.green, 0), width=1, style=line.style_solid)
            line.new(bar_index, _sl,   _rb, _sl,   color=color.new(color.red, 0),   width=1, style=line.style_dashed)
            line.new(bar_index, _tp1,  _rb, _tp1,  color=color.new(#69f0ae, 30),    width=1, style=line.style_dotted)
            line.new(bar_index, _tp2,  _rb, _tp2,  color=color.new(#00e676, 0),     width=2, style=line.style_dotted)

    if final_sell
        _sl       = short_sl
        _tp1      = f_short_tp(close, _sl, tp1_rr)
        _tp2      = f_short_tp(close, _sl, tp2_rr)
        _cts      = ruby_sell_contracts
        _cts_full = math.max(1, math.round(_cts / CT_FRATIO))
        _risk_usd = f_move_dollars(close, _sl, _cts)
        _tp1_usd  = f_move_dollars(close, _tp1, _cts)
        _tp2_usd  = f_move_dollars(close, _tp2, _cts)

        label.new(bar_index, high + atr_14,
             "SELL  " + contract_type + "\n" +
             "Entry: " + str.tostring(close, "#.##") + "\n" +
             "SL:    " + str.tostring(_sl, "#.##") + "  (-$" + str.tostring(math.round(_risk_usd, 0)) + ")\n" +
             "TP1:   " + str.tostring(_tp1, "#.##") + "  (+$" + str.tostring(math.round(_tp1_usd, 0)) + ")  " + str.tostring(tp1_rr, "#.#") + "R\n" +
             "TP2:   " + str.tostring(_tp2, "#.##") + "  (+$" + str.tostring(math.round(_tp2_usd, 0)) + ")  " + str.tostring(tp2_rr, "#.#") + "R\n" +
             str.tostring(_cts) + "× " + contract_type +
             (show_full_size ? "  /  " + str.tostring(_cts_full) + "× " + CT_FSYMBOL : "") + "\n" +
             "Q: " + str.tostring(math.round(signal_quality_score * 100, 0)) + "%  Wave: " + str.tostring(math.round(math.abs(current_ratio_avg), 2)) + "x",
             color=color.new(color.red,20), style=label.style_label_down, textcolor=color.black, size=size.normal)

        if show_tp_lines
            _rb = bar_index + tp_line_length
            line.new(bar_index, close, _rb, close, color=color.new(color.red, 0),    width=1, style=line.style_solid)
            line.new(bar_index, _sl,   _rb, _sl,   color=color.new(color.red, 0),    width=1, style=line.style_dashed)
            line.new(bar_index, _tp1,  _rb, _tp1,  color=color.new(#69f0ae, 30),     width=1, style=line.style_dotted)
            line.new(bar_index, _tp2,  _rb, _tp2,  color=color.new(#00e676, 0),      width=2, style=line.style_dotted)

// Entry zones
var box   support_zone     = na
var box   resistance_zone  = na
var label support_label    = na
var label resistance_label = na

if show_entry_zones
    if barstate.islast
        support_bottom    = lowest_src
        support_top       = lowest_src + (highest_src - lowest_src) * 0.1
        resistance_bottom = highest_src - (highest_src - lowest_src) * 0.1
        resistance_top    = highest_src

        if na(support_zone)
            support_zone    := box.new(bar_index[20], support_bottom, bar_index, support_top,       bgcolor=color.new(color.aqua,90),   border_color=color.new(color.green,70))
            resistance_zone := box.new(bar_index[20], resistance_top, bar_index, resistance_bottom, bgcolor=color.new(color.yellow,90), border_color=color.new(color.red,70))
        else
            box.set_lefttop(support_zone,    bar_index[20], support_top)
            box.set_rightbottom(support_zone,    bar_index, support_bottom)
            box.set_lefttop(resistance_zone, bar_index[20], resistance_top)
            box.set_rightbottom(resistance_zone, bar_index, resistance_bottom)

        support_mid    = (support_bottom + support_top) / 2
        resistance_mid = (resistance_bottom + resistance_top) / 2

        if na(support_label)
            support_label    := label.new(bar_index - 10, support_mid,    "S: " + str.tostring(support_bottom, "#.####"),  color=color.new(color.aqua,100),   textcolor=color.new(color.green,30), style=label.style_label_center, size=size.small)
            resistance_label := label.new(bar_index - 10, resistance_mid, "R: " + str.tostring(resistance_top, "#.####"),  color=color.new(color.yellow,100), textcolor=color.new(color.red,30),   style=label.style_label_center, size=size.small)
        else
            label.set_xy(support_label,    bar_index - 10, support_mid)
            label.set_text(support_label,    "S: " + str.tostring(support_bottom, "#.####"))
            label.set_xy(resistance_label, bar_index - 10, resistance_mid)
            label.set_text(resistance_label, "R: " + str.tostring(resistance_top, "#.####"))

// ==================================================================================
// ENGINE SIGNAL OVERLAY — request.seed() AUTO or MANUAL
// ==================================================================================
//
// request.seed() reads per-asset OHLCV seed files from GitHub.
// Column encoding:
//   open   = entry price
//   high   = stop loss
//   low    = TP1
//   close  = TP2
//   volume = packed integer: dir_code * 1000000 + cnn_int * 100 + tp3_offset
//     dir_code:  1 = LONG, 2 = SHORT
//     cnn_int:   round(cnn_prob * 10000) → 0..10000
//     tp3_offset: abs(tp3 - entry) * 100, capped at 99
//
// Pine decodes volume → direction, CNN probability, TP3.
// If seed data is unavailable or expired, falls back to manual inputs.
// ==================================================================================

f_contract_to_seed(ct) =>
    switch ct
        "MGC" => "gold"
        "MES" => "sp500"
        "MNQ" => "nasdaq"
        "MYM" => "dow_jones"
        "M2K" => "russell_2000"
        "6E"  => "euro_fx"
        "6B"  => "british_pound"
        "6J"  => "japanese_yen"
        "MBT" => "bitcoin"
        "MET" => "ethereum"
        => "gold"

_seed_asset = engine_seed_asset == "auto" ? f_contract_to_seed(contract_type) : engine_seed_asset
_seed_sym   = "seed/" + _seed_asset

// Read each field separately — request.seed() returns one expression at a time
_sd_entry_raw = request.seed(engine_seed_repo, _seed_sym, open,   ignore_invalid_symbol = true)
_sd_stop_raw  = request.seed(engine_seed_repo, _seed_sym, high,   ignore_invalid_symbol = true)
_sd_tp1_raw   = request.seed(engine_seed_repo, _seed_sym, low,    ignore_invalid_symbol = true)
_sd_tp2_raw   = request.seed(engine_seed_repo, _seed_sym, close,  ignore_invalid_symbol = true)
_sd_vol_raw   = request.seed(engine_seed_repo, _seed_sym, volume, ignore_invalid_symbol = true)
_sd_time_raw  = request.seed(engine_seed_repo, _seed_sym, time,   ignore_invalid_symbol = true)

// Decode packed volume
_sd_vol_int  = int(math.round(nz(_sd_vol_raw, 0)))
_sd_dir_code = math.floor(_sd_vol_int / 1000000)
_sd_cnn_raw  = math.floor((_sd_vol_int % 1000000) / 100)
_sd_cnn_prob = _sd_cnn_raw / 10000.0
_sd_tp3_off  = _sd_vol_int % 100

_sd_is_long  = _sd_dir_code == 1
_sd_dir_str  = _sd_is_long ? "LONG" : "SHORT"
_sd_entry    = nz(_sd_entry_raw, 0.0)
_sd_stop     = nz(_sd_stop_raw,  0.0)
_sd_tp1      = nz(_sd_tp1_raw,   0.0)
_sd_tp2      = nz(_sd_tp2_raw,   0.0)
_sd_tp3_val  = _sd_tp3_off / 100.0
_sd_tp3      = _sd_is_long ? _sd_entry + _sd_tp3_val : _sd_entry - _sd_tp3_val

// Expiry check
_sd_age_ms    = nz(_sd_time_raw, 0) > 0 ? (timenow - nz(_sd_time_raw, 0)) : 0
_sd_expiry_ms = engine_seed_expiry_h * 60 * 60 * 1000
_sd_expired   = _sd_age_ms > _sd_expiry_ms or _sd_age_ms <= 0
_sd_valid     = not na(_sd_entry_raw) and _sd_entry > 0 and _sd_stop > 0 and not _sd_expired and _sd_dir_code >= 1 and _sd_dir_code <= 2

// Resolve effective values: seed overrides manual when valid
_use_seed    = engine_auto_mode and _sd_valid

eff_active   = _use_seed ? true         : engine_active
eff_dir      = _use_seed ? _sd_dir_str  : engine_dir
eff_entry    = _use_seed ? _sd_entry    : engine_entry
eff_sl       = _use_seed ? _sd_stop     : engine_sl
eff_cnn      = _use_seed ? _sd_cnn_prob : engine_cnn

// For TP: if manual TPs are provided, use them. Otherwise compute from R:R.
_eng_risk     = math.abs(eff_entry - eff_sl)
_eng_is_long  = eff_dir == "LONG"

_default_tp1 = _eng_is_long ? eff_entry + _eng_risk * tp1_rr : eff_entry - _eng_risk * tp1_rr
_default_tp2 = _eng_is_long ? eff_entry + _eng_risk * tp2_rr : eff_entry - _eng_risk * tp2_rr
_default_tp3 = _eng_is_long ? eff_entry + _eng_risk * 3.0    : eff_entry - _eng_risk * 3.0

eff_tp1 = _use_seed ? (_sd_tp1 > 0 ? _sd_tp1 : _default_tp1) : (engine_tp1 > 0 ? engine_tp1 : _default_tp1)
eff_tp2 = _use_seed ? (_sd_tp2 > 0 ? _sd_tp2 : _default_tp2) : (engine_tp2 > 0 ? engine_tp2 : _default_tp2)
eff_tp3 = _use_seed ? (_sd_tp3 > 0 and _sd_tp3_off > 0 ? _sd_tp3 : _default_tp3) : (engine_tp3 > 0 ? engine_tp3 : _default_tp3)

// ==================================================================================
// ENGINE SIGNAL LINES (Entry / SL / TP1 / TP2 / TP3)
// Lightweight: just lines + labels on chart edge. No dashboard table.
// ==================================================================================
_e_cts_micro = eff_entry > 0 and eff_sl > 0 ? f_calc_contracts(eff_entry, eff_sl) : 1
_e_cts_full  = math.max(1, math.round(_e_cts_micro / CT_FRATIO))
_e_risk      = eff_entry > 0 ? f_move_dollars(eff_entry, eff_sl,  _e_cts_micro) : 0.0
_e_tp1_usd   = eff_entry > 0 ? f_move_dollars(eff_tp1,  eff_entry, _e_cts_micro) : 0.0
_e_tp2_usd   = eff_entry > 0 ? f_move_dollars(eff_tp2,  eff_entry, _e_cts_micro) : 0.0
_e_tp3_usd   = eff_entry > 0 ? f_move_dollars(eff_tp3,  eff_entry, _e_cts_micro) : 0.0

var line  _l_entry = na
var line  _l_sl    = na
var line  _l_tp1   = na
var line  _l_tp2   = na
var line  _l_tp3   = na
var label _lb_entry = na
var label _lb_sl    = na
var label _lb_tp1   = na
var label _lb_tp2   = na
var label _lb_tp3   = na
var label _lb_cnn   = na

_eng_src = _use_seed ? "SEED" : "MANUAL"

if show_engine_lines and eff_active and eff_entry > 0 and barstate.islast
    _dir_col = _eng_is_long ? color.new(#00e676, 0) : color.new(#ff1744, 0)
    _lb = bar_index - 30
    _rb = bar_index + 50

    // Clean up previous
    if not na(_l_entry)
        line.delete(_l_entry)
        line.delete(_l_sl)
        line.delete(_l_tp1)
        line.delete(_l_tp2)
        line.delete(_l_tp3)
    if not na(_lb_entry)
        label.delete(_lb_entry)
        label.delete(_lb_sl)
        label.delete(_lb_tp1)
        label.delete(_lb_tp2)
        label.delete(_lb_tp3)
    if not na(_lb_cnn)
        label.delete(_lb_cnn)

    // Lines
    _l_entry := line.new(_lb, eff_entry, _rb, eff_entry, color=_dir_col,                   width=2, style=line.style_solid)
    _l_sl    := line.new(_lb, eff_sl,    _rb, eff_sl,    color=color.new(#ff1744, 0),      width=2, style=line.style_dashed)
    _l_tp1   := line.new(_lb, eff_tp1,   _rb, eff_tp1,  color=color.new(#69f0ae, 50),     width=1, style=line.style_dotted)
    _l_tp2   := line.new(_lb, eff_tp2,   _rb, eff_tp2,  color=color.new(#69f0ae, 20),     width=1, style=line.style_dotted)
    _l_tp3   := line.new(_lb, eff_tp3,   _rb, eff_tp3,  color=color.new(#b9f6ca, 0),      width=2, style=line.style_solid)

    // Labels
    _lb_entry := label.new(_rb, eff_entry,
         "ENTRY " + str.tostring(eff_entry, "#.##") + "  [" + _eng_src + "]\n" +
         str.tostring(_e_cts_micro) + "× " + contract_type +
         (show_full_size ? " / " + str.tostring(_e_cts_full) + "× " + CT_FSYMBOL : "") +
         "\nRisk: -$" + str.tostring(math.round(_e_risk, 0)),
         color=color.new(_dir_col, 15), textcolor=color.white, style=label.style_label_left, size=size.small)

    _lb_sl := label.new(_rb, eff_sl,
         "SL " + str.tostring(eff_sl, "#.##") + "  -$" + str.tostring(math.round(_e_risk, 0)),
         color=color.new(#ff1744, 15), textcolor=color.white, style=label.style_label_left, size=size.small)

    _tp1_rr_txt = _eng_risk > 0 ? "  " + str.tostring(math.round(math.abs(eff_tp1 - eff_entry) / _eng_risk, 1), "#.#") + "R" : ""
    _lb_tp1 := label.new(_rb, eff_tp1,
         "TP1 " + str.tostring(eff_tp1, "#.##") + "  +$" + str.tostring(math.round(_e_tp1_usd, 0)) + _tp1_rr_txt,
         color=color.new(#69f0ae, 15), textcolor=color.white, style=label.style_label_left, size=size.small)

    _tp2_rr_txt = _eng_risk > 0 ? "  " + str.tostring(math.round(math.abs(eff_tp2 - eff_entry) / _eng_risk, 1), "#.#") + "R" : ""
    _lb_tp2 := label.new(_rb, eff_tp2,
         "TP2 " + str.tostring(eff_tp2, "#.##") + "  +$" + str.tostring(math.round(_e_tp2_usd, 0)) + _tp2_rr_txt,
         color=color.new(#69f0ae, 15), textcolor=color.white, style=label.style_label_left, size=size.small)

    _tp3_rr_txt = _eng_risk > 0 ? "  " + str.tostring(math.round(math.abs(eff_tp3 - eff_entry) / _eng_risk, 1), "#.#") + "R" : ""
    _lb_tp3 := label.new(_rb, eff_tp3,
         "TP3 " + str.tostring(eff_tp3, "#.##") + "  +$" + str.tostring(math.round(_e_tp3_usd, 0)) + _tp3_rr_txt,
         color=color.new(#b9f6ca, 10), textcolor=color.white, style=label.style_label_left, size=size.small)

    // CNN badge above entry
    if show_cnn_badge and eff_cnn > 0
        _cnn_pct = math.round(eff_cnn * 100, 1)
        _cnn_col = eff_cnn >= 0.85 ? color.new(#00e676, 10) : eff_cnn >= 0.75 ? color.new(#ffab40, 10) : color.new(#ff1744, 10)
        _badge_y = _eng_is_long ? eff_entry + _eng_risk * 0.3 : eff_entry - _eng_risk * 0.3
        _badge_txt = "CNN " + str.tostring(_cnn_pct) + "% " + eff_dir + (_use_seed ? "  ● AUTO" : "")
        _lb_cnn := label.new(bar_index, _badge_y, _badge_txt, color=_cnn_col, textcolor=color.white, style=label.style_label_down, size=size.normal)

// ==================================================================================
// ALERTS
// ==================================================================================
alertcondition(final_buy,       title = "Ruby BUY",        message = "{{ticker}} 🟢 BUY " + contract_type + " | Entry: {{close}}")
alertcondition(final_sell,      title = "Ruby SELL",       message = "{{ticker}} 🔴 SELL " + contract_type + " | Entry: {{close}}")
alertcondition(regime_changed,  title = "Regime Change",   message = "{{ticker}} 🔄 Regime Changed")
alertcondition(session_started, title = "Session Start",   message = "{{ticker}} ⏰ Session OPEN")
alertcondition(session_ended,   title = "Session End",     message = "{{ticker}} ⏰ Session CLOSED")
alertcondition(orb_breakout_up, title = "ORB Up",          message = "{{ticker}} 🚀 ORB BREAK UP")
alertcondition(orb_breakout_dn, title = "ORB Down",        message = "{{ticker}} 📉 ORB BREAK DN")
alertcondition(ib_breakout_up,  title = "IB Up",           message = "{{ticker}} 🔵 IB BREAK UP")
alertcondition(ib_breakout_dn,  title = "IB Down",         message = "{{ticker}} 🟠 IB BREAK DN")
alertcondition(squeeze_fired,   title = "Squeeze",         message = "{{ticker}} 💥 SQUEEZE FIRED")

// Hidden plots for alert templates
plot(show_plot_values ? trendspeed                : na, "Trend Speed",    display = display.none)
plot(show_plot_values ? current_ratio_avg         : na, "Wave Ratio",     display = display.none)
plot(show_plot_values ? signal_quality_score * 100: na, "Signal Quality", display = display.none)
plot(show_plot_values ? orb_high : na, "ORB High", display = display.none)
plot(show_plot_values ? orb_low  : na, "ORB Low",  display = display.none)
plot(show_plot_values ? eff_cnn  : na, "CNN Prob",  display = display.none)
// Expose TP levels for indicator-on-indicator use
plot(show_plot_values and final_buy  ? f_long_tp(close,  long_sl,  tp1_rr) : na, "Buy TP1",  display = display.none)
plot(show_plot_values and final_buy  ? f_long_tp(close,  long_sl,  tp2_rr) : na, "Buy TP2",  display = display.none)
plot(show_plot_values and final_sell ? f_short_tp(close, short_sl, tp1_rr) : na, "Sell TP1", display = display.none)
plot(show_plot_values and final_sell ? f_short_tp(close, short_sl, tp2_rr) : na, "Sell TP2", display = display.none)
plot(show_plot_values ? breakout_strength : na, "Breakout Str", display = display.none)
plot(show_plot_values ? vol_percentile    : na, "Vol %ile",     display = display.none)
