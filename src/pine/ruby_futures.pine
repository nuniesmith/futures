// Ruby Futures — Top G Channel, S/R levels, entry zones, and volume bar coloring
//@version=6
indicator("Ruby Futures", shorttitle="Ruby Futures", overlay=true,
     max_boxes_count=100, max_lines_count=500, max_labels_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// 1. RANGE SETTINGS
// ══════════════════════════════════════════════════════════════════════════════
rangeType     = input.string("ORB", "Range Type",
     options=["ORB", "Prev Day Range", "Asian Range", "London Range", "Custom Range"],
     group="1. Range Settings")
orbMinutes    = input.int(30,      "ORB Minutes",             minval=5,  maxval=120, group="1. Range Settings")
customSess    = input.session("0000-2359", "Custom Range Session",                   group="1. Range Settings")

// ══════════════════════════════════════════════════════════════════════════════
// 2. STRATEGY
// ══════════════════════════════════════════════════════════════════════════════
biasMode      = input.string("Auto", "Session Bias",
     options=["Auto", "Long Only", "Short Only"], group="2. Strategy")
requireVWAP   = input.bool(true,  "Require VWAP Alignment",                          group="2. Strategy")
volMult       = input.float(1.25, "Volume Spike × Avg",      minval=0.8, step=0.05,  group="2. Strategy")
minQualityPct = input.int(60,     "Minimum Quality %",        minval=30,  maxval=95,  group="2. Strategy")
allowAdd      = input.bool(true,  "Allow One ADD on Pullback",                        group="2. Strategy")

// ══════════════════════════════════════════════════════════════════════════════
// 3. PLOTS
// ══════════════════════════════════════════════════════════════════════════════
showEMA       = input.bool(true,  "Show EMA9",            group="3. Plots")
showVWAP      = input.bool(true,  "Show VWAP",            group="3. Plots")
showBB        = input.bool(false, "Show Bollinger Bands", group="3. Plots")
showTable     = input.bool(true,  "Show Ruby Dashboard",  group="3. Plots")
dashPosition  = input.string("Top Right", "Dashboard Position",
     options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"], group="3. Plots")

// ══════════════════════════════════════════════════════════════════════════════
// 4. TOP G CHANNEL
// ══════════════════════════════════════════════════════════════════════════════
showTopG          = input.bool(true,  "Show Top G Channel",      group="4. Top G Channel")
topGLength        = input.int(150,    "Channel Range Length",     minval=20, group="4. Top G Channel")
showTopGMid       = input.bool(true,  "Show Mid Line",            group="4. Top G Channel")
showTopGSignals   = input.bool(true,  "Show Strong Channel Signals", group="4. Top G Channel")
showSimpleSigs    = input.bool(false, "Show Simple Signals (noisy)", group="4. Top G Channel")
showPotentialSigs = input.bool(false, "Show Potential Signals",      group="4. Top G Channel")
showEntryZones    = input.bool(true,  "Show Entry Zones",         group="4. Top G Channel")
signalSensitivity = input.float(0.5,  "Signal Sensitivity",
     minval=0.1, maxval=2.0, step=0.1,                           group="4. Top G Channel")

// ══════════════════════════════════════════════════════════════════════════════
// 5. S/R LEVELS
// ══════════════════════════════════════════════════════════════════════════════
showSR      = input.bool(true,  "Show HTF S/R Levels",    group="5. S/R Levels")
show1mSR    = input.bool(false, "Show 1m S/R (fine)",     group="5. S/R Levels")
srLookback  = input.int(20,     "S/R Lookback Periods",   minval=5, group="5. S/R Levels")
srThreshold = input.float(0.3,  "S/R Sensitivity",        minval=0.1, maxval=1.0, step=0.1, group="5. S/R Levels")

// ══════════════════════════════════════════════════════════════════════════════
// 6. BAR COLORING
// ══════════════════════════════════════════════════════════════════════════════
// Volume mode:   candles are dim when quiet, bright green/red when high volume hits
// Heatmap mode:  Ruby "weather" — price above/below regression line drives yellow→red / aqua→yellow
barColorMode  = input.string("Heatmap",   "Bar Color Mode",
     options=["Off", "Volume", "Heatmap"],                        group="6. Bar Coloring")
heatSensitive = input.int(70, "Heatmap Sensitivity", minval=10,   group="6. Bar Coloring")

// ══════════════════════════════════════════════════════════════════════════════
// 7. Ruby SIGNALS  (Top G + AO confirmed entries)
// ══════════════════════════════════════════════════════════════════════════════
showRubySignals  = input.bool(true,  "Show Ruby Long/Short Signals",  group="7. Ruby Signals")
showRubyAdd      = input.bool(true,  "Show Ruby ADD Points",          group="7. Ruby Signals")
rubyVolConfirm   = input.bool(true,  "Require Volume Confirmation",   group="7. Ruby Signals")
rubyBiasConfirm  = input.bool(true,  "Require Session Bias Match",    group="7. Ruby Signals")
rubyAddBars      = input.int(25,     "ADD Lookback Window (bars)",
     minval=5, maxval=60,                                            group="7. Ruby Signals")
rubyAOFast       = input.int(5,      "AO Fast Period",  minval=2,    group="7. Ruby Signals")
rubyAOSlow       = input.int(34,     "AO Slow Period",  minval=5,    group="7. Ruby Signals")
// ══════════════════════════════════════════════════════════════════════════════

// Normalize a series relative to its mean (clamps to ±5 σ)
normalization(_src, _mean) =>
    _stdev = ta.stdev(_src, 200)
    _norm  = _stdev == 0 ? 0 : (_src - _mean) / _stdev
    math.max(math.min(_norm, 5), -5)

// Linear regression line value for the current bar
f_regression_line(_len) =>
    _x     = bar_index
    _y     = hl2
    _x_    = ta.sma(_x, _len)
    _y_    = ta.sma(_y, _len)
    _mx    = ta.stdev(_x, _len)
    _my    = ta.stdev(_y, _len)
    _corr  = ta.correlation(_x, _y, _len)
    _slope = _mx == 0 ? 0 : _corr * (_my / _mx)
    _inter = _y_ - _slope * _x_
    _x * _slope + _inter

// ══════════════════════════════════════════════════════════════════════════════
// TOP G CHANNEL FUNCTIONS 
// ══════════════════════════════════════════════════════════════════════════════

// Support / Resistance / Mid bands
f_lowest_highest(_len) =>
    float _lo  = ta.lowest(low,  _len)
    float _hi  = ta.highest(high, _len)
    float _mid = ta.hma(math.avg(_lo, _hi), 15)
    [_lo, _hi, _mid]

// Normalised rate-of-change — computed once per bar, then offset via [] in signal logic
// This matches the original Top G which does: roc = ta.roc(close, 8) / ta.stdev(roc, 200)
// and then references roc[2].
f_calc_norm_roc() =>
    float _roc   = ta.roc(close, 8)
    float _stdev = ta.stdev(_roc, 200)
    _stdev == 0 ? 0.0 : _roc / _stdev

// Signal detection: channel touches, bounces, and early-warning zones
// Returns [top, bottom, simple_bot, simple_top, pot_bot, pot_top]
f_signals(_lo, _hi, _atr, _norm_roc) =>
    float _sup_zone  = _lo + _atr * 0.5
    float _res_zone  = _hi - _atr * 0.5

    // Strong signals — require double-touch / momentum confirmation
    // Use _norm_roc[2] (output offset) to match original: roc[2] > 2
    bool _top     = high < _hi and high[1] == _hi[1] and _norm_roc[2] >  2 * signalSensitivity and _lo == _lo[5] and barstate.isconfirmed
    bool _bot     = low[1] == _lo[1] and low > _lo and low[2] == _lo[2] and _norm_roc[2] < -2 * signalSensitivity and barstate.isconfirmed

    // Simple signals — single-bar touch and bounce (visual only)
    bool _s_bot   = low[1]  == _lo[1] and low  > _lo and not _bot and barstate.isconfirmed
    bool _s_top   = high < _hi and high[1] == _hi[1] and not _top and barstate.isconfirmed

    // Potential / early-warning — price entering zone with momentum
    bool _p_bot   = low  <= _sup_zone and _norm_roc < -1 * signalSensitivity and barstate.isconfirmed
    bool _p_top   = high >= _res_zone and _norm_roc >  1 * signalSensitivity and barstate.isconfirmed

    [_top, _bot, _s_bot, _s_top, _p_bot, _p_top]

// ══════════════════════════════════════════════════════════════════════════════
// S/R SWING DETECTION FUNCTIONS 
// ══════════════════════════════════════════════════════════════════════════════

// ── Returns the most recent confirmed swing HIGH as a scalar series
f_swing_high_val(_src, _len, _thr) =>
    float _hi  = ta.highest(_src, _len - 1)
    float _lo  = ta.lowest(_src,  _len * 2)
    float _atr = ta.atr(14)
    bool  _is  = _src[_len] > _src[_len + 1] and _src[_len] > _src[_len - 1] and
                 _src[_len] > _hi and (_src[_len] - _lo) / _atr > _thr
    ta.valuewhen(_is, _src[_len], 0)

// ── Returns the most recent confirmed swing LOW as a scalar series
f_swing_low_val(_src, _len, _thr) =>
    float _lo  = ta.lowest(_src,  _len - 1)
    float _hi  = ta.highest(_src, _len * 2)
    float _atr = ta.atr(14)
    bool  _is  = _src[_len] < _src[_len + 1] and _src[_len] < _src[_len - 1] and
                 _src[_len] < _lo and (_hi - _src[_len]) / _atr > _thr
    ta.valuewhen(_is, _src[_len], 0)

// ── Replaces get_nearest_sr_levels() — returns scalars, safe for request.security
get_nearest_sr_levels(_tf) =>
    _res = request.security(syminfo.tickerid, _tf,
         f_swing_high_val(high, srLookback, srThreshold), lookahead=barmerge.lookahead_off)
    _sup = request.security(syminfo.tickerid, _tf,
         f_swing_low_val(low,  srLookback, srThreshold),  lookahead=barmerge.lookahead_off)
    [_res, _sup]

// ══════════════════════════════════════════════════════════════════════════════
// SESSION & TIME
// ══════════════════════════════════════════════════════════════════════════════
rthSess = "0300-1600"   // ← adjust for non-US futures
inRTH   = not na(time("1", rthSess))
newDay  = ta.change(time("D")) != 0

// ══════════════════════════════════════════════════════════════════════════════
// CORE INDICATORS
// ══════════════════════════════════════════════════════════════════════════════
ema9                  = ta.ema(close, 9)
[_, bbUpper, bbLower] = ta.bb(close, 20, 2)
vwap                  = ta.vwap(hlc3)
ao                    = ta.sma(hlc3, 5) - ta.sma(hlc3, 34)
volAvg                = ta.sma(volume, 20)
atr14                 = ta.atr(14)

// ══════════════════════════════════════════════════════════════════════════════
// BAR COLORING  (heatmap + volume mode)
// ══════════════════════════════════════════════════════════════════════════════

// ── Heatmap: normalise price deviation above/below regression line
//    Above → yellow→red gradient ("hot"); below → aqua→yellow ("cold")
reg_line    = f_regression_line(topGLength)
color_level = normalization(close - reg_line, 0)
color heatmap_bar_color = color_level > 0
     ? color.from_gradient(color_level, 0,
          math.max(ta.highest(color_level, heatSensitive), 0.0001), color.yellow, color.red)
     : color.from_gradient(color_level,
          math.min(ta.lowest(color_level, heatSensitive), -0.0001), 0, color.aqua, color.yellow)

// ── Volume: dim when quiet, bright when volume spikes
//    Bullish candle → teal (low) → lime (high volume)
//    Bearish candle → maroon (low) → red (high volume)
_vol_ratio       = volume / volAvg
_vol_norm        = math.min(_vol_ratio / 3.0, 1.0)   // 0‒1, caps at 3× avg
_bull_candle     = close >= open
color vol_bar_color = _bull_candle
     ? color.from_gradient(_vol_norm, 0, 1, color.new(color.teal,   80), color.new(color.lime, 0))
     : color.from_gradient(_vol_norm, 0, 1, color.new(color.maroon, 80), color.new(color.red,  0))

barcolor(barColorMode == "Heatmap" ? heatmap_bar_color :
         barColorMode == "Volume"  ? vol_bar_color      : na)

// ══════════════════════════════════════════════════════════════════════════════
// TOP G CHANNEL CALCULATIONS 
// ══════════════════════════════════════════════════════════════════════════════
[tg_lo, tg_hi, tg_mid] = f_lowest_highest(topGLength)
tg_norm_roc = f_calc_norm_roc()
[tg_top, tg_bot, tg_s_bot, tg_s_top, tg_p_bot, tg_p_top] = f_signals(tg_lo, tg_hi, atr14, tg_norm_roc)
float tg_range = tg_hi - tg_lo

// ══════════════════════════════════════════════════════════════════════════════
// S/R LEVEL CALCULATIONS 
// ══════════════════════════════════════════════════════════════════════════════
var float sr_res_1m = na
var float sr_sup_1m = na
var float sr_res_5m = na
var float sr_sup_5m = na

if showSR
    [_r1, _s1] = get_nearest_sr_levels("1")
    [_r5, _s5] = get_nearest_sr_levels("5")
    sr_res_1m := _r1
    sr_sup_1m := _s1
    sr_res_5m := _r5
    sr_sup_5m := _s5
else
    sr_res_1m := na
    sr_sup_1m := na
    sr_res_5m := na
    sr_sup_5m := na

// ══════════════════════════════════════════════════════════════════════════════
// HOISTED HISTORICAL CALLS
// ta.change / ta.crossover / ta.crossunder must execute every bar (not inside
// conditionals) so Pine's history buffers stay consistent.
// ══════════════════════════════════════════════════════════════════════════════
bool _asian_sess_change  = ta.change(time("1", "0500-1700")) != 0
bool _london_sess_change = ta.change(time("1", "1000-0200")) != 0
bool _asian_sess_start   = ta.change(time("1", "1700-0500")) != 0
bool _london_sess_start  = ta.change(time("1", "0200-1000")) != 0
bool _custom_sess_start  = ta.change(time("1", customSess))  != 0

// ══════════════════════════════════════════════════════════════════════════════
// RANGE BUILDING
// ══════════════════════════════════════════════════════════════════════════════
var float  rHigh      = na
var float  rLow       = na
var bool   rangeReady = false
var string rangeName  = ""

// Hoisted here so rHigh/rLow are in scope
bool _cross_high = ta.crossover( high, nz(rHigh))
bool _cross_low  = ta.crossunder(low,  nz(rLow))

if newDay
    rHigh      := na
    rLow       := na
    rangeReady := false

// 1. ORB
if rangeType == "ORB"
    rangeName := "ORB"
    int barsSinceOpen = ta.barssince(newDay)
    if barsSinceOpen * timeframe.multiplier <= orbMinutes and inRTH
        rHigh := math.max(nz(rHigh, high), high)
        rLow  := math.min(nz(rLow,  low),  low)
    else if not rangeReady and not na(rHigh)
        rangeReady := true

// 2. Previous Day Range
if rangeType == "Prev Day Range"
    rangeName  := "PD Range"
    rHigh      := request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
    rLow       := request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)
    rangeReady := true

// 3. Asian Range
if rangeType == "Asian Range"
    rangeName := "Asian"
    string asianSess = "1700-0500"
    if _asian_sess_start
        rHigh := high
        rLow  := low
    if not na(time("1", asianSess))
        rHigh := math.max(nz(rHigh), high)
        rLow  := math.min(nz(rLow),  low)
    if not rangeReady and _asian_sess_change
        rangeReady := true

// 4. London Range
if rangeType == "London Range"
    rangeName  := "London"
    string londonSess = "0200-1000"
    if _london_sess_start
        rHigh := high
        rLow  := low
    if not na(time("1", londonSess))
        rHigh := math.max(nz(rHigh), high)
        rLow  := math.min(nz(rLow),  low)
    if not rangeReady and _london_sess_change
        rangeReady := true

// 5. Custom Range
if rangeType == "Custom Range"
    rangeName := "Custom"
    if _custom_sess_start
        rHigh := high
        rLow  := low
    if not na(time("1", customSess))
        rHigh := math.max(nz(rHigh), high)
        rLow  := math.min(nz(rLow),  low)
    if not rangeReady and not na(rHigh) and na(time("1", customSess))
        rangeReady := true

// ══════════════════════════════════════════════════════════════════════════════
// SESSION BIAS
// ══════════════════════════════════════════════════════════════════════════════
htTrend   = request.security(syminfo.tickerid, "240", close > ta.ema(close, 50) ? 1 : -1)
int bullVotes = 0
bullVotes += (biasMode == "Long Only" or htTrend == 1) ? 1 : 0
bullVotes += ao > 0 ? 1 : 0
bullVotes += close > vwap ? 1 : 0
bullBias   = biasMode == "Long Only" or (biasMode == "Auto" and bullVotes >= 2)

// ══════════════════════════════════════════════════════════════════════════════
// QUALITY SCORE
// ══════════════════════════════════════════════════════════════════════════════
quality = 0.0
quality += (bullBias and ao > ao[1]) or (not bullBias and ao < ao[1]) ? 20 : 0
quality += close > ema9 and bullBias or close < ema9 and not bullBias ? 15 : 0
quality += bullBias ? (close > vwap ? 20 : 0) : (close < vwap ? 20 : 0)
quality += volume > volAvg * volMult ? 25 : 0
quality += rangeReady and ((bullBias and close > rHigh) or (not bullBias and close < rLow)) ? 20 : 0
quality := math.min(100, math.max(0, quality))

// ══════════════════════════════════════════════════════════════════════════════
// BREAKOUT + ADD SIGNALS
// ══════════════════════════════════════════════════════════════════════════════
var bool  breakoutFired = false
var bool  addFired      = false
var int   breakoutBar   = na
var float breakoutPrice = na

if newDay
    breakoutFired := false
    addFired      := false
    breakoutBar   := na
    breakoutPrice := na

longBreak  = rangeReady and _cross_high and      bullBias and not breakoutFired
shortBreak = rangeReady and _cross_low  and not bullBias and not breakoutFired

volOK       = volume > volAvg * volMult
vwapOKLong  = not requireVWAP or close > vwap
vwapOKShort = not requireVWAP or close < vwap
qualityOK   = quality >= minQualityPct

longBreakout  = longBreak  and volOK and vwapOKLong  and qualityOK
shortBreakout = shortBreak and volOK and vwapOKShort and qualityOK

if longBreakout or shortBreakout
    breakoutFired := true
    breakoutBar   := bar_index
    breakoutPrice := close
    addFired      := false

longAdd  = allowAdd and breakoutFired and not addFired and
           (bar_index - breakoutBar) <= 30 and (bar_index - breakoutBar) >= 3 and
           bullBias and low <= math.max(vwap, ema9) + atr14 * 0.3 and
           close > ema9 and volume > volAvg * 0.7

shortAdd = allowAdd and breakoutFired and not addFired and
           (bar_index - breakoutBar) <= 30 and (bar_index - breakoutBar) >= 3 and
           not bullBias and high >= math.min(vwap, ema9) - atr14 * 0.3 and
           close < ema9 and volume > volAvg * 0.7

if longAdd or shortAdd
    addFired := true

// ══════════════════════════════════════════════════════════════════════════════
// Ruby SIGNAL ENGINE
// Confirmed long/short: Top G strong bounce/rejection + AO alignment
//                       + session bias (optional) + volume (optional)
// Ruby ADD: Top G touch signal within rubyAddBars after the initial signal
// ══════════════════════════════════════════════════════════════════════════════

// Shared AO (may differ from Ruby's ao which uses hlc3; Ruby AO uses hl2)
ruby_ao = ta.sma(hl2, rubyAOFast) - ta.sma(hl2, rubyAOSlow)

_ruby_vol_ok     = not rubyVolConfirm  or volume > volAvg * volMult
_ruby_long_bias  = not rubyBiasConfirm or bullBias
_ruby_short_bias = not rubyBiasConfirm or not bullBias

// ── Primary signals: TG strong bounce/rejection confirmed by AO direction
rubyLong  = showRubySignals and tg_bot and ruby_ao > 0 and _ruby_long_bias  and _ruby_vol_ok and barstate.isconfirmed
rubyShort = showRubySignals and tg_top and ruby_ao < 0 and _ruby_short_bias and _ruby_vol_ok and barstate.isconfirmed

// Track when the most recent Ruby signal fired
var int rubyLongBar  = na
var int rubyShortBar = na

if rubyLong
    rubyLongBar  := bar_index
if rubyShort
    rubyShortBar := bar_index

// ── ADD points: any TG touch (simple or potential) within the lookback window
//    after a signal, while price remains on the right side of the channel mid
_bars_since_ruby_long  = na(rubyLongBar)  ? 9999 : bar_index - rubyLongBar
_bars_since_ruby_short = na(rubyShortBar) ? 9999 : bar_index - rubyShortBar

rubyAddLong  = showRubyAdd and
              _bars_since_ruby_long  >= 2 and _bars_since_ruby_long  <= rubyAddBars and
              (tg_s_bot or tg_p_bot) and close > tg_mid and ruby_ao > 0 and
              not rubyLong   // don't double-mark the initial signal bar

rubyAddShort = showRubyAdd and
              _bars_since_ruby_short >= 2 and _bars_since_ruby_short <= rubyAddBars and
              (tg_s_top or tg_p_top) and close < tg_mid and ruby_ao < 0 and
              not rubyShort

// ══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════════════════════════

// ── Ruby ORB / Range bands
pRHigh = plot(rangeReady ? rHigh : na, "Range High", color.new(#2962FF, 0), 2)
pRLow  = plot(rangeReady ? rLow  : na, "Range Low",  color.new(#2962FF, 0), 2)
fill(pRHigh, pRLow, color.new(#2962FF, 85), title="Range Zone")

plot(showEMA  ? ema9    : na, "EMA9",     color.new(#00BFFF, 0), 2)
plot(showVWAP ? vwap    : na, "VWAP",     color.new(#FF00FF, 0), 2)
plot(showBB   ? bbUpper : na, "BB Upper", color.new(#FF5252, 0), 1, plot.style_linebr)
plot(showBB   ? bbLower : na, "BB Lower", color.new(#00E676, 0), 1, plot.style_linebr)

// ── Top G Channel bands — dashed lines only, no fill, lighter weight
pTGHigh = plot(showTopG            ? tg_hi  : na, "TG Resistance", color.new(#ff1100, 50), 1, plot.style_linebr)
pTGLow  = plot(showTopG            ? tg_lo  : na, "TG Support",    color.new(#00ffbb, 50), 1, plot.style_linebr)
plot(showTopG and showTopGMid      ? tg_mid : na, "TG Mid",        color.new(color.gray, 75), 1, plot.style_linebr)

// ── HTF S/R — true horizontal lines via line.new(), only redrawn when level shifts
//    This prevents the staircase pattern caused by plot() updating every bar.
var line _ln_res_5m = na
var line _ln_sup_5m = na
var line _ln_res_1m = na
var line _ln_sup_1m = na
var float _last_res_5m = na
var float _last_sup_5m = na
var float _last_res_1m = na
var float _last_sup_1m = na

_sr_threshold = atr14 * 0.15   // only redraw if level moved more than 15% of ATR

if showSR and barstate.isconfirmed
    if not na(sr_res_5m) and (na(_last_res_5m) or math.abs(sr_res_5m - _last_res_5m) > _sr_threshold)
        line.delete(_ln_res_5m)
        _ln_res_5m    := line.new(bar_index, sr_res_5m, bar_index + 1, sr_res_5m,
             extend=extend.right, color=color.new(color.red, 25), width=2, style=line.style_dashed)
        _last_res_5m  := sr_res_5m

    if not na(sr_sup_5m) and (na(_last_sup_5m) or math.abs(sr_sup_5m - _last_sup_5m) > _sr_threshold)
        line.delete(_ln_sup_5m)
        _ln_sup_5m    := line.new(bar_index, sr_sup_5m, bar_index + 1, sr_sup_5m,
             extend=extend.right, color=color.new(color.green, 25), width=2, style=line.style_dashed)
        _last_sup_5m  := sr_sup_5m

    if show1mSR
        if not na(sr_res_1m) and (na(_last_res_1m) or math.abs(sr_res_1m - _last_res_1m) > _sr_threshold)
            line.delete(_ln_res_1m)
            _ln_res_1m   := line.new(bar_index, sr_res_1m, bar_index + 1, sr_res_1m,
                 extend=extend.right, color=color.new(color.red, 55), width=1, style=line.style_dotted)
            _last_res_1m := sr_res_1m

        if not na(sr_sup_1m) and (na(_last_sup_1m) or math.abs(sr_sup_1m - _last_sup_1m) > _sr_threshold)
            line.delete(_ln_sup_1m)
            _ln_sup_1m   := line.new(bar_index, sr_sup_1m, bar_index + 1, sr_sup_1m,
                 extend=extend.right, color=color.new(color.green, 55), width=1, style=line.style_dotted)
            _last_sup_1m := sr_sup_1m

// ── Breakout / ADD arrows
plotshape(series=longBreakout,  title="Breakout Long",  style=shape.triangleup,   location=location.belowbar, color=color.lime,          size=size.large,  text="BREAKOUT")
plotshape(series=shortBreakout, title="Breakout Short", style=shape.triangledown, location=location.abovebar, color=color.red,           size=size.large,  text="BREAKOUT")
plotshape(series=longAdd,       title="ADD Long",       style=shape.triangleup,   location=location.belowbar, color=color.new(#00BFFF,0), size=size.normal, text="ADD")
plotshape(series=shortAdd,      title="ADD Short",      style=shape.triangledown, location=location.abovebar, color=color.orange,        size=size.normal, text="ADD")

// ── Top G channel signals
//    Strong bounce/rejection: solid circle (normal size)
//    Single-bar touch:        faded circle (small)
//    Potential / early entry: diamond (tiny)
plotshape(series=showTopGSignals and tg_bot,    title="TG Strong Support",    style=shape.circle,  location=location.belowbar, color=color.new(#00ffbb, 0),  size=size.normal)
plotshape(series=showTopGSignals and tg_top,    title="TG Strong Resistance", style=shape.circle,  location=location.abovebar, color=color.new(#ff1100, 0),  size=size.normal)
plotshape(series=showSimpleSigs and tg_s_bot,  title="TG Simple Support",    style=shape.circle,  location=location.belowbar, color=color.new(#00ffbb, 45), size=size.small)
plotshape(series=showSimpleSigs and tg_s_top,  title="TG Simple Resistance", style=shape.circle,  location=location.abovebar, color=color.new(#ff1100, 45), size=size.small)
plotshape(series=showPotentialSigs and tg_p_bot, title="TG Potential Support", style=shape.diamond, location=location.belowbar, color=color.new(#00ffbb, 60), size=size.tiny)
plotshape(series=showPotentialSigs and tg_p_top, title="TG Potential Resist",  style=shape.diamond, location=location.abovebar, color=color.new(#ff1100, 60), size=size.tiny)

// ── Ruby Long / Short confirmed signals — star shape, clearly distinct from breakout arrows
plotshape(series=rubyLong,      title="Ruby Long",       style=shape.labelup,     location=location.belowbar, color=color.new(#00ff88, 0),  size=size.normal, text="L")
plotshape(series=rubyShort,     title="Ruby Short",      style=shape.labeldown,   location=location.abovebar, color=color.new(#ff4444, 0),  size=size.normal, text="S")

// ── Ruby ADD points — smaller, offset slightly further so they don't overlap
plotshape(series=rubyAddLong,   title="Ruby ADD Long",   style=shape.triangleup,  location=location.belowbar, color=color.new(#00ffbb, 20), size=size.small,  text="+L")
plotshape(series=rubyAddShort,  title="Ruby ADD Short",  style=shape.triangledown,location=location.abovebar, color=color.new(#ff8888, 20), size=size.small,  text="+S")

// ── Background tint (existing — uses chart background, not candle colour)
bgcolor(close > ema9 and ao > 0  ? color.new(color.lime, 96) :
        close < ema9 and ao < 0  ? color.new(color.red,  96) : na)

// ── Entry zone boxes
//    Highlight the bottom 10 % and top 10 % of the Top G channel — the
//    "fair value" / congestion zones where breakouts typically launch from.
if showEntryZones and barstate.islast and not na(tg_range) and tg_range > 0
    var box _sup_box = box.new(bar_index[20], tg_lo + tg_range * 0.1, bar_index, tg_lo,
         bgcolor=color.new(color.teal, 88), border_color=color.new(color.green, 55))
    var box _res_box = box.new(bar_index[20], tg_hi, bar_index, tg_hi - tg_range * 0.1,
         bgcolor=color.new(color.red,  90), border_color=color.new(color.red,   55))
    box.set_right(_sup_box, bar_index)
    box.set_top(  _sup_box, tg_lo + tg_range * 0.1)
    box.set_bottom(_sup_box, tg_lo)
    box.set_right(_res_box, bar_index)
    box.set_top(  _res_box, tg_hi)
    box.set_bottom(_res_box, tg_hi - tg_range * 0.1)

// ══════════════════════════════════════════════════════════════════════════════
// RUBY DASHBOARD
// ══════════════════════════════════════════════════════════════════════════════
_dashPos = dashPosition == "Bottom Right" ? position.bottom_right :
           dashPosition == "Top Left"     ? position.top_left     :
           dashPosition == "Bottom Left"  ? position.bottom_left  : position.top_right
var table dash = table.new(_dashPos, 2, 14,
     bgcolor=color.new(#1e222d, 80), border_width=1, frame_color=#00ffff)

if barstate.islast and showTable
    // ── Header
    table.cell(dash, 0, 0,  "RUBY FUTURES",  text_color=#00ffff, text_size=size.normal)
    table.cell(dash, 1, 0,  "",              text_color=color.white, text_size=size.normal)

    // ── ORB / Range
    table.cell(dash, 0, 1,  "Range",   text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 1,  rangeName + " | " + biasMode,
         text_color=color.yellow, text_size=size.normal)

    table.cell(dash, 0, 2,  "Levels",  text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 2,  rangeReady
         ? str.tostring(rHigh, "#.##") + " / " + str.tostring(rLow, "#.##")
         : "BUILDING",
         text_color=#00ffff, text_size=size.normal)

    // ── Core metrics
    table.cell(dash, 0, 3,  "Quality", text_color=color.gray, text_size=size.normal)
    table.cell(dash, 1, 3,  str.tostring(math.round(quality)) + "%",
         text_color=quality >= 70 ? color.lime : quality >= 50 ? color.yellow : color.red,
         text_size=size.normal)

    table.cell(dash, 0, 4,  "VWAP",    text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 4,  str.tostring(vwap, "#.##"),
         text_color=#FF00FF, text_size=size.normal)

    table.cell(dash, 0, 5,  "AO",      text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 5,  str.tostring(ao, "#.##"),
         text_color=ao > 0 ? color.lime : color.red, text_size=size.normal)

    table.cell(dash, 0, 6,  "Vol",     text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 6,  str.tostring(volume / volAvg, "0.00") + "×",
         text_color=volume > volAvg * volMult ? color.lime : color.gray, text_size=size.normal)

    // ── Top G Channel
    table.cell(dash, 0, 7,  "TG Chan", text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 7,
         str.tostring(tg_hi, "#.##") + " / " + str.tostring(tg_lo, "#.##"),
         text_color=color.white, text_size=size.normal)

    // ── TG Signal status
    _tg_sig_txt = tg_bot   ? "⬆ STRONG BOUNCE" :
                  tg_top   ? "⬇ STRONG REJECT"  :
                  tg_s_bot ? "^ bounce"          :
                  tg_s_top ? "v reject"          : "—"
    _tg_sig_col = tg_bot or tg_s_bot ? color.lime : tg_top or tg_s_top ? color.red : color.gray
    table.cell(dash, 0, 8,  "TG Sig",  text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 8,  _tg_sig_txt, text_color=_tg_sig_col, text_size=size.normal)

    // ── HTF S/R
    table.cell(dash, 0, 9,  "1m S/R",  text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 9,
         (not na(sr_res_1m) ? str.tostring(sr_res_1m, "#.##") : "--") + " / " +
         (not na(sr_sup_1m) ? str.tostring(sr_sup_1m, "#.##") : "--"),
         text_color=color.white, text_size=size.normal)

    table.cell(dash, 0, 10, "5m S/R",  text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 10,
         (not na(sr_res_5m) ? str.tostring(sr_res_5m, "#.##") : "--") + " / " +
         (not na(sr_sup_5m) ? str.tostring(sr_sup_5m, "#.##") : "--"),
         text_color=color.white, text_size=size.normal)

    // ── Bar colour mode indicator
    table.cell(dash, 0, 11, "Bars",    text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 11, barColorMode,
         text_color=barColorMode == "Off" ? color.gray : color.new(#00BFFF, 0), text_size=size.normal)

    // ── Ruby Signal status
    _ruby_long_txt  = rubyLong  ? "▲ SIGNAL"  :
                     rubyAddLong ? "+ ADD"    :
                     not na(rubyLongBar) and _bars_since_ruby_long <= rubyAddBars ? "watching (" + str.tostring(_bars_since_ruby_long) + ")" : "—"
    _ruby_short_txt = rubyShort ? "▼ SIGNAL"  :
                     rubyAddShort ? "+ ADD"   :
                     not na(rubyShortBar) and _bars_since_ruby_short <= rubyAddBars ? "watching (" + str.tostring(_bars_since_ruby_short) + ")" : "—"
    _ruby_long_col  = rubyLong or rubyAddLong ? color.lime   :
                     not na(rubyLongBar) and _bars_since_ruby_long <= rubyAddBars ? color.yellow : color.gray
    _ruby_short_col = rubyShort or rubyAddShort ? color.red  :
                     not na(rubyShortBar) and _bars_since_ruby_short <= rubyAddBars ? color.yellow : color.gray

    table.cell(dash, 0, 12, "Ruby L",   text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 12, _ruby_long_txt,  text_color=_ruby_long_col,  text_size=size.normal)

    table.cell(dash, 0, 13, "Ruby S",   text_color=color.gray,   text_size=size.normal)
    table.cell(dash, 1, 13, _ruby_short_txt, text_color=_ruby_short_col, text_size=size.normal)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════════════
alertcondition(longBreakout or shortBreakout,
     title="Ruby Breakout",
     message="Ruby {{ticker}} {{interval}} BREAKOUT")

alertcondition(longAdd or shortAdd,
     title="Ruby ADD",
     message="Ruby {{ticker}} {{interval}} ADD on pullback")

alertcondition(tg_bot,
     title="Ruby TG Strong Bounce",
     message="Ruby {{ticker}} {{interval}} TG STRONG BOUNCE — support held")

alertcondition(tg_top,
     title="Ruby TG Strong Rejection",
     message="Ruby {{ticker}} {{interval}} TG STRONG REJECTION — resistance held")

alertcondition(tg_p_bot or tg_p_top,
     title="Ruby TG Potential Signal",
     message="Ruby {{ticker}} {{interval}} TG price entering channel zone")

alertcondition(rubyLong,
     title="Ruby Ruby Long Signal",
     message="Ruby {{ticker}} {{interval}} Ruby LONG — TG bounce + AO bullish confirmed")

alertcondition(rubyShort,
     title="Ruby Ruby Short Signal",
     message="Ruby {{ticker}} {{interval}} Ruby SHORT — TG rejection + AO bearish confirmed")

alertcondition(rubyAddLong,
     title="Ruby Ruby ADD Long",
     message="Ruby {{ticker}} {{interval}} Ruby ADD LONG — pullback to TG support zone")

alertcondition(rubyAddShort,
     title="Ruby Ruby ADD Short",
     message="Ruby {{ticker}} {{interval}} Ruby ADD SHORT — pullback to TG resistance zone")

alertcondition(rubyLong or rubyShort or rubyAddLong or rubyAddShort,
     title="Ruby Ruby All Signals",
     message="Ruby {{ticker}} {{interval}} Ruby signal fired")
