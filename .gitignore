# =============================================================================
# Futures Trading Co-Pilot — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# --- Virtual environments ---
.venv/
venv/
ENV/

# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Data & databases ---
*.db
*.sqlite
*.sqlite3
/data/
archive/

# --- Logs ---
*.log
logs/

# --- Test / coverage artifacts ---
.coverage
htmlcov/
.pytest_cache/
.ruff_cache/

# --- Claude / AI ---
.claude/

# --- Docker volumes (local) ---
postgres_data/
redis_data/
grafana_data/
prometheus_data/

# --- Analysis output ---
codebase_summary.md

# =============================================================================
# CNN Models — pulled from orb repo via scripts/sync_models.sh
# =============================================================================
# Model files are not committed to this repo. They are downloaded on demand
# from https://github.com/nuniesmith/orb/tree/main/models.
# The models/ directory is kept (via .gitkeep) so Docker bind-mounts work
# after a fresh clone, but all model artifacts are gitignored.
models/*
!models/.gitkeep
