# =============================================================================
# Futures Trader — .gitignore
# =============================================================================

# ─── Virtual Environments ────────────────────────────────────────
.venv/
venv/
env/

# ─── Environment Variables (secrets — NEVER commit) ─────────────
.env

# ─── Python ──────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/

# ─── Tool Caches ────────────────────────────────────────────────
.mypy_cache/
.pytest_cache/
.ruff_cache/
.cache/

# ─── IDE / Editor ───────────────────────────────────────────────
.vscode/
.zed/
.idea/
*.swp
*.swo
*~

# ─── Logs & Data ────────────────────────────────────────────────
*.log
logs/
data/

# ─── Docker ─────────────────────────────────────────────────────
.dockerignore

# ─── OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Ruby Reference Code ────────────────────────────────────────
# Kept locally for reference but not shipped in the repo.
# Delete ruby/ once all code has been ported.
ruby/

# ─── Poetry (if used) ──────────────────────────────────────────
poetry.lock
