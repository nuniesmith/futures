*.pyc
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# --- Virtual environments ---
.venv/
venv/
ENV/

# --- Environment & secrets ---
.env
.env.*
!.env.example

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Data & databases ---
*.db
