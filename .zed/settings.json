{
  "languages": {
    "Python": {
      "language_servers": ["ruff", "!pyright"],
      "formatter": "language_server",
      "format_on_save": "on",
      "tab_size": 4,
    },
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 100,
          "lint": {
            "select": ["E", "F", "W", "I", "UP", "B", "SIM", "RUF"],
            "ignore": ["E501"],
          },
        },
      },
    },
  },
}
