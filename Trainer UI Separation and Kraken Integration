                  elif [ "${{ needs.docker.result }}" = "skipped" ]; then
                    echo "### ⏭️ Docker build skipped" >> $GITHUB_STEP_SUMMARY
                    echo "Docker builds only run on push to main." >> $GITHUB_STEP_SUMMARY
                  fi

                  echo "" >> $GITHUB_STEP_SUMMARY
                  echo "### 🐳 Docker Tags" >> $GITHUB_STEP_SUMMARY
                  echo "" >> $GITHUB_STEP_SUMMARY
                  echo "| Service | Tag | Pinned Tag | Platforms |" >> $GITHUB_STEP_SUMMARY
                  echo "|---------|-----|------------|-----------|" >> $GITHUB_STEP_SUMMARY
                  echo "| Engine | \`${{ env.IMAGE_NAME }}:engine\` | \`:engine-${SHA_SHORT}\` | amd64, arm64 |" >> $GITHUB_STEP_SUMMARY
                  echo "| Web | \`${{ env.IMAGE_NAME }}:web\` | \`:web-${SHA_SHORT}\` | amd64, arm64 |" >> $GITHUB_STEP_SUMMARY
                  echo "| Trainer | \`${{ env.IMAGE_NAME }}:trainer\` | \`:trainer-${SHA_SHORT}\` | amd64 |" >> $GITHUB_STEP_SUMMARY
                  echo "| Default | \`${{ env.IMAGE_NAME }}:latest\` | — | amd64, arm64 |" >> $GITHUB_STEP_SUMMARY
                  echo "" >> $GITHUB_STEP_SUMMARY
                  echo "| Property | Value |" >> $GITHUB_STEP_SUMMARY
                  echo "|----------|-------|" >> $GITHUB_STEP_SUMMARY
                  echo "| 🐍 Python | \`${{ env.PYTHON_VERSION }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "| 📦 Repo | \`${{ env.IMAGE_NAME }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "| 🌿 Branch | \`${{ github.ref_name }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "| 🔗 Commit | \`${{ github.sha }}\` |" >> $GITHUB_STEP_SUMMARY

            - name: ❌ Fail on critical errors
              if: needs.lint.result == 'failure' || needs.test.result == 'failure' || needs.docker.result == 'failure' || needs.deploy.result == 'failure'
              run: |
                  echo "❌ Pipeline had failures"
                  echo "  Lint:   ${{ needs.lint.result }}"
                  echo "  Test:   ${{ needs.test.result }}"
                  echo "  Docker: ${{ needs.docker.result }}"
                  echo "  Deploy: ${{ needs.deploy.result }}"
                  exit 1

