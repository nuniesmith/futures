#   - DISCORD_WEBHOOK_ACTIONS: Discord webhook for CI/CD notifications
#   - XAI_API_KEY: xAI (Grok) API key injected into prod .env
#   - MASSIVE_API_KEY: Massive API key injected into prod .env
#   - KRAKEN_API_KEY: Kraken API key injected into prod .env
# =============================================================================

name: 🚀 CI/CD Pipeline

on:
    push:
        branches: [main]
        paths-ignore:
            - "**.md"
            - "LICENSE"
            - ".gitignore"
            - "docs/**"
    pull_request:
        branches: [main]
    workflow_dispatch:
        inputs:
            skip_tests:
                description: "Skip tests (build only)"
                required: false
                type: boolean
                default: false
            skip_docker:
                description: "Skip Docker build (test only)"
                required: false
                type: boolean
                default: false
            skip_deploy:
                description: "Skip Pi deploy (build only)"
                required: false
                type: boolean
                default: false

permissions:
    contents: read
    packages: write
    checks: write

env:
    PYTHON_VERSION: "3.13"
    REGISTRY: docker.io
    IMAGE_NAME: nuniesmith/futures

concurrency:
    group: ${{ github.workflow }}-${{ github.ref }}
    cancel-in-progress: true

defaults:
    run:
        shell: bash

jobs:
    # =========================================================================
    # Stage 1: Lint & Format
    # =========================================================================
    lint:
        name: ✨ Lint & Format
        runs-on: ubuntu-latest
        timeout-minutes: 10
        if: ${{ !inputs.skip_tests }}
        steps:
            - name: 📥 Checkout code
              uses: actions/checkout@v4

            - name: 📣 Notify build started
              continue-on-error: true
              uses: nuniesmith/actions/.github/actions/discord-notify@main
              with:
                  webhook-url: ${{ secrets.DISCORD_WEBHOOK_ACTIONS }}
                  title: "🔨 Futures CI/CD Started"
                  description: "Running lint and format checks"
                  status: started
                  include-repo-info: "true"

            - name: 🐍 Setup Python
              uses: actions/setup-python@v5
              with:
                  python-version: ${{ env.PYTHON_VERSION }}

            - name: 📦 Install linting tools
              run: |
                  python -m pip install --upgrade pip
                  pip install ruff mypy

            - name: ✨ Run Ruff linting
              run: |
                  echo "🔍 Running Ruff linter..."
                  ruff check . --output-format=github
                  ruff format --check .

            - name: 🔍 Run mypy type check
              run: |
                  echo "🔍 Running mypy type checker..."
                  if [ -f pyproject.toml ]; then pip install -e ".[dev]" 2>/dev/null || pip install -e . 2>/dev/null || true; fi
                  mypy . --ignore-missing-imports || true

    # =========================================================================
    # Stage 2: Test
    # =========================================================================
    test:
        name: 🧪 Test
        runs-on: ubuntu-latest
        timeout-minutes: 20
        if: ${{ !inputs.skip_tests }}
        needs: lint
        steps:
            - name: 📥 Checkout code
              uses: actions/checkout@v4

            - name: 🐍 Setup Python
              uses: actions/setup-python@v5
              with:
                  python-version: ${{ env.PYTHON_VERSION }}
                  cache: "pip"

            - name: 📦 Install dependencies
              run: |
                  python -m pip install --upgrade pip
                  pip install pytest pytest-cov pytest-asyncio pytest-timeout
                  if [ -f pyproject.toml ]; then pip install -e ".[dev]" 2>/dev/null || pip install -e . 2>/dev/null || true; fi

            - name: 🧪 Run tests
              run: |
                  pytest --cov=. --cov-report=xml --cov-report=term-missing -v

            - name: ✅ Notify tests passed
              if: success()
              continue-on-error: true
              uses: nuniesmith/actions/.github/actions/discord-notify@main
              with:
                  webhook-url: ${{ secrets.DISCORD_WEBHOOK_ACTIONS }}
                  title: "✅ Futures Tests Passed"
                  description: "All tests and lint checks passed"
                  status: success

            - name: ❌ Notify tests failed
              if: failure()
              continue-on-error: true
              uses: nuniesmith/actions/.github/actions/discord-notify@main
              with:
                  webhook-url: ${{ secrets.DISCORD_WEBHOOK_ACTIONS }}
                  title: "❌ Futures Tests Failed"
                  description: "Tests or lint checks failed"
                  status: failure
                  fields: '[{"name": "Workflow", "value": "[View Logs](https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }})", "inline": false}]'

    # =========================================================================
    # Stage 3: Build & Push Docker Images
    # =========================================================================
    #
    # Single DockerHub repo (nuniesmith/futures) with tag-per-service.
    # Each matrix entry produces two tags:
    #   :engine           (rolling latest for that service)
    #   :engine-abc1234   (pinned to commit SHA)
    # The engine build also tags :latest as the default pull target.
    #
    # Builds run in parallel via matrix strategy:
    #   engine  — Combined FastAPI data service + engine worker (arm64 + amd64)
    #   web     — HTMX dashboard reverse-proxy (arm64 + amd64)
    #   trainer — GPU CNN training server (amd64 only — CUDA base image)
    # =========================================================================
    docker:
        name: "🐳 Build :${{ matrix.service }}"
        needs: test
        runs-on: ubuntu-latest
        timeout-minutes: 60
        if: |
            github.event_name == 'push' && github.ref == 'refs/heads/main'
            && (github.event_name != 'workflow_dispatch' || inputs.skip_docker != true)
        strategy:
            fail-fast: false
            matrix:
                include:
                    - service: engine
                      dockerfile: docker/engine/Dockerfile
                      platforms: linux/amd64,linux/arm64
                      is_default: true
                    - service: web
                      dockerfile: docker/web/Dockerfile
                      platforms: linux/amd64,linux/arm64
                      is_default: false
                    - service: trainer
                      dockerfile: docker/trainer/Dockerfile
                      platforms: linux/amd64
                      is_default: false
        steps:
            - name: 📥 Checkout code
              uses: actions/checkout@v4

            - name: 🔢 Compute short SHA
              id: vars
              run: echo "sha_short=$(echo ${{ github.sha }} | cut -c1-7)" >> "$GITHUB_OUTPUT"

            - name: 🐳 Build and Push — :${{ matrix.service }}
              uses: nuniesmith/actions/.github/actions/docker-build-push@main
              with:
                  image-name: ${{ env.IMAGE_NAME }}
                  username: ${{ secrets.DOCKER_USERNAME }}
                  password: ${{ secrets.DOCKER_TOKEN }}
                  dockerfile: ${{ matrix.dockerfile }}
                  context: .
                  platforms: ${{ matrix.platforms }}
                  push: "true"
                  tags: |
                      type=raw,value=${{ matrix.service }}
                      type=raw,value=${{ matrix.service }}-${{ steps.vars.outputs.sha_short }}
                      type=raw,value=latest,enable=${{ matrix.is_default }}

            - name: ✅ Notify :${{ matrix.service }} pushed
              if: success()
              continue-on-error: true
              uses: nuniesmith/actions/.github/actions/discord-notify@main
              with:
                  webhook-url: ${{ secrets.DISCORD_WEBHOOK_ACTIONS }}
                  title: "🐳 :${{ matrix.service }} Image Pushed"
                  description: "Docker image pushed to Docker Hub"
                  status: success
                  fields: '[{"name": "Tags", "value": "`${{ env.IMAGE_NAME }}:${{ matrix.service }}`\n`${{ env.IMAGE_NAME }}:${{ matrix.service }}-${{ steps.vars.outputs.sha_short }}`", "inline": true}, {"name": "Platforms", "value": "`${{ matrix.platforms }}`", "inline": true}]'

            - name: ❌ Notify :${{ matrix.service }} build failed
              if: failure()
              continue-on-error: true
              uses: nuniesmith/actions/.github/actions/discord-notify@main
              with:
                  webhook-url: ${{ secrets.DISCORD_WEBHOOK_ACTIONS }}
                  title: "❌ :${{ matrix.service }} Docker Build Failed"
                  description: "Failed to build or push :${{ matrix.service }} image"
                  status: failure
                  fields: '[{"name": "Dockerfile", "value": "`${{ matrix.dockerfile }}`", "inline": true}, {"name": "Workflow", "value": "[View Logs](https://github.com/${{ github.repository }}/actions/runs/${{ github.run_id }})", "inline": false}]'

    # =========================================================================
    # Stage 4: Deploy to Production (Raspberry Pi via Tailscale)
    # =========================================================================
    #
    # Connects to the Pi over Tailscale VPN, then uses the shared ssh-deploy
    # action to pull the freshly-pushed :engine and :web images (arm64 variants)
    # and restart the services via docker compose.
    #
    # The :trainer image is NOT deployed to the Pi (GPU rig only).
    #
    # Gates:
    #   - Only runs on push to main (same gate as docker stage)
    #   - Only runs after ALL docker matrix jobs succeed
    #   - Can be skipped manually via workflow_dispatch skip_deploy input
    # =========================================================================
    deploy:
        name: 🚀 Deploy to Raspberry Pi
        needs: docker
        runs-on: ubuntu-latest
        timeout-minutes: 15
        if: |
            github.event_name == 'push' && github.ref == 'refs/heads/main'
            && (github.event_name != 'workflow_dispatch' || inputs.skip_deploy != true)
        steps:
            - name: 📥 Checkout code
              uses: actions/checkout@v4

            - name: 🔢 Compute short SHA
              id: vars
              run: echo "sha_short=$(echo ${{ github.sha }} | cut -c1-7)" >> "$GITHUB_OUTPUT"

            - name: 🔌 Connect to Tailscale
              id: tailscale
              uses: nuniesmith/actions/.github/actions/tailscale-connect@main
              with:
                  oauth-client-id: ${{ secrets.TAILSCALE_OAUTH_CLIENT_ID }}
                  oauth-secret: ${{ secrets.TAILSCALE_OAUTH_SECRET }}
                  target-ip: ${{ secrets.PROD_TAILSCALE_IP }}
                  target-ssh-port: ${{ secrets.PROD_SSH_PORT || '22' }}

            - name: 🚀 Deploy via SSH
              id: deploy
              if: steps.tailscale.outputs.connected == 'true'
              uses: nuniesmith/actions/.github/actions/ssh-deploy@main
              with:
                  host: ${{ secrets.PROD_TAILSCALE_IP }}
                  port: ${{ secrets.PROD_SSH_PORT || '22' }}
                  username: ${{ secrets.PROD_SSH_USER || 'actions' }}
                  ssh-key: ${{ secrets.PROD_SSH_KEY }}
                  project-path: ~/futures
                  git-pull: false
                  git-branch: main
                  docker-prune: false
                  pre-deploy-command: |
                      echo "📦 Preparing Futures deployment on Raspberry Pi..."

                      # Handle git repository setup
                      if [ ! -d "$HOME/futures/.git" ]; then
                        if [ -d "$HOME/futures" ]; then
                          echo "📁 Directory exists but is not a git repo — initializing..."
                          cd ~/futures
                          git init
                          git remote add origin https://github.com/${{ github.repository }}.git
                          git fetch origin
                          git checkout -f main
                          git branch --set-upstream-to=origin/main main
                        else
                          echo "📥 First deployment — cloning repository..."
                          git clone https://github.com/${{ github.repository }}.git ~/futures
                          cd ~/futures
                          git checkout main
                        fi
                      else
                        cd ~/futures
                        echo "📥 Pulling latest changes..."
                        git fetch origin
                        git checkout main
                        git pull origin main
                      fi

                      # Ensure scripts are executable
                      find . -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true

                      # Create .env file if it doesn't exist
                      if [ ! -f ".env" ]; then
                        echo "📝 Creating default .env..."
                        cat > .env <<'ENVEOF'
                      # Futures Environment Configuration
                      PYTHONUNBUFFERED=1
                      LOG_LEVEL=info
                      ENVEOF
                        chmod 600 .env
                        echo "✅ Created .env file"
                      else
                        echo "✅ Using existing .env file"
                      fi

                      # Upsert API keys — always overwrite so rotated secrets stay current
                      echo "🔑 Injecting API keys into .env..."
                      upsert_env() {
                        local key="$1" val="$2"
                        if grep -q "^${key}=" .env 2>/dev/null; then
                          sed -i "s|^${key}=.*|${key}=${val}|" .env
                        else
                          echo "${key}=${val}" >> .env
                        fi
                      }
                      upsert_env "XAI_API_KEY"        "${{ secrets.XAI_API_KEY }}"
                      upsert_env "MASSIVE_API_KEY"     "${{ secrets.MASSIVE_API_KEY }}"
                      upsert_env "KRAKEN_API_KEY"      "${{ secrets.KRAKEN_API_KEY }}"
                      upsert_env "KRAKEN_API_SECRET"   "${{ secrets.KRAKEN_API_SECRET }}"
                      chmod 600 .env
                      echo "✅ API keys injected"

                      # Create required directories
                      echo "📁 Ensuring data directories exist..."
                      mkdir -p data config
                      chmod 755 data config
                      echo "✅ Directories ready"

                  deploy-command: |
                      cd ~/futures

                      # Stop existing services
                      echo "🐳 Stopping existing services..."
                      docker compose -f docker-compose.prod.yml down 2>/dev/null || \
                        docker compose down 2>/dev/null || true

                      # Log in to Docker Hub and pull latest per-service images
                      echo "🐳 Pulling latest images from Docker Hub..."
                      echo "${{ secrets.DOCKER_TOKEN }}" | docker login -u "${{ secrets.DOCKER_USERNAME }}" --password-stdin 2>/dev/null || true

                      echo "==> Pulling :engine image..."
                      docker pull ${{ env.IMAGE_NAME }}:engine

                      echo "==> Pulling :web image..."
                      docker pull ${{ env.IMAGE_NAME }}:web

                      # Start services (trainer is GPU-rig only — not deployed to Pi)
                      echo "🚀 Starting engine and web services..."
                      docker compose -f docker-compose.prod.yml up -d --no-build --remove-orphans engine web 2>/dev/null || \
                        docker compose up -d --no-build --remove-orphans

                  post-deploy-command: |
                      cd ~/futures

                      echo ""
                      echo "📊 Container status:"
                      docker compose -f docker-compose.prod.yml ps engine web 2>/dev/null || \
                        docker ps --filter "name=futures" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"

                      echo ""
                      echo "📊 Storage usage:"
                      df -h / | grep -v Filesystem
                      docker system df 2>/dev/null || true

                      # Prune dangling images to save space on Raspberry Pi
                      echo ""
                      echo "🧹 Pruning dangling Docker images..."
                      docker image prune -f 2>/dev/null || true

                      echo ""
                      echo "🎯 Architecture:"
                      uname -m
                      docker info --format '{{.Architecture}}' 2>/dev/null || true

                      echo ""
                      echo "✅ Futures deployment complete!"

            - name: 🏥 Run Health Checks
              id: health-checks
              if: always() && steps.deploy.outcome == 'success'
              uses: nuniesmith/actions/.github/actions/health-check@main
              with:
                  containers: futures
                  ssh-host: ${{ secrets.PROD_TAILSCALE_IP }}
                  ssh-port: ${{ secrets.PROD_SSH_PORT || '22' }}
                  ssh-user: ${{ secrets.PROD_SSH_USER || 'actions' }}
                  ssh-key: ${{ secrets.PROD_SSH_KEY }}
                  initial-delay: 15
                  retry-count: 3
                  retry-delay: 10
                  fail-on-unhealthy: false

            - name: 📣 Notify deployment
              if: always()
              uses: nuniesmith/actions/.github/actions/discord-notify@main
              continue-on-error: true
              with:
                  webhook-url: ${{ secrets.DISCORD_WEBHOOK_ACTIONS }}
                  title: "${{ steps.deploy.outcome == 'success' && '🚀 Futures Deployed to Pi' || '❌ Futures Pi Deploy Failed' }}"
                  description: "${{ steps.deploy.outcome == 'success' && 'Engine + Web updated on Raspberry Pi' || 'Failed to deploy Futures to Raspberry Pi' }}"
                  status: ${{ steps.deploy.outcome == 'success' && 'success' || 'failure' }}
                  include-repo-info: "true"
                  fields: |
                      [
                        {"name": "Platform", "value": "🥧 Raspberry Pi (ARM64)", "inline": true},
                        {"name": "Images", "value": "`${{ env.IMAGE_NAME }}:engine`\n`${{ env.IMAGE_NAME }}:web`", "inline": true},
                        {"name": "Commit", "value": "`${{ steps.vars.outputs.sha_short }}`", "inline": true},
                        {"name": "Network", "value": "🔒 Tailscale VPN", "inline": true},
                        {"name": "Health", "value": "${{ steps.health-checks.outputs.healthy == 'true' && '✅ Healthy' || '⚠️ Check logs' }}", "inline": true}
                      ]

    # =========================================================================
    # Pipeline Summary
    # =========================================================================
    summary:
        name: 📊 Pipeline Summary
        runs-on: ubuntu-latest
        timeout-minutes: 5
        needs: [lint, test, docker, deploy]
        if: always()
        steps:
            - name: 📊 Generate summary
              run: |
                  SHA_SHORT=$(echo "${{ github.sha }}" | cut -c1-7)

                  echo "## 📊 Futures CI/CD Pipeline Summary" >> $GITHUB_STEP_SUMMARY
                  echo "" >> $GITHUB_STEP_SUMMARY
                  echo "| Stage | Status |" >> $GITHUB_STEP_SUMMARY
                  echo "|-------|--------|" >> $GITHUB_STEP_SUMMARY
                  echo "| ✨ Lint & Format | \`${{ needs.lint.result }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "| 🧪 Test | \`${{ needs.test.result }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "| 🐳 Docker Build & Push | \`${{ needs.docker.result }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "| 🚀 Deploy to Raspberry Pi | \`${{ needs.deploy.result }}\` |" >> $GITHUB_STEP_SUMMARY
                  echo "" >> $GITHUB_STEP_SUMMARY

                  if [ "${{ needs.lint.result }}" = "success" ] && \
                     [ "${{ needs.test.result }}" = "success" ] && \
                     [ "${{ needs.docker.result }}" = "success" ]; then
                    DEPLOY="${{ needs.deploy.result }}"
                    if [ "$DEPLOY" = "success" ]; then
                      echo "### ✅ All stages completed — Pi updated!" >> $GITHUB_STEP_SUMMARY
                    elif [ "$DEPLOY" = "skipped" ]; then
                      echo "### ✅ Build + test passed (Pi deploy skipped)" >> $GITHUB_STEP_SUMMARY
                    elif [ "$DEPLOY" = "failure" ]; then
                      echo "### ⚠️ Build passed but Pi deploy failed — check Tailscale / SSH secrets" >> $GITHUB_STEP_SUMMARY
                    else
                      echo "### ✅ All stages completed successfully!" >> $GITHUB_STEP_SUMMARY
                    fi
                  elif [ "${{ needs.lint.result }}" = "failure" ]; then
                    echo "### ❌ Pipeline failed at lint stage" >> $GITHUB_STEP_SUMMARY
                    echo "Fix linting/formatting errors before proceeding." >> $GITHUB_STEP_SUMMARY
