                sum(1 for r in results if r.is_trade),
            )

        elif _bt == BreakoutType.Monthly:
            logger.info(
                "Simulating Monthly trades for %s (%d bars)...",
                symbol,
                len(bars_1m),
            )
            results = simulate_batch_monthly(
                bars_1m=bars_1m,
