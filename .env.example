# ================================================================
# Sol Scalper — Environment Config
# Copy this to .env and fill in your real values.
# NEVER commit .env to git.
# ================================================================

# KuCoin Futures API credentials
KUCOIN_API_KEY=your_api_key_here
KUCOIN_API_SECRET=your_api_secret_here
KUCOIN_PASSPHRASE=your_passphrase_here

# Discord webhook for trade alerts (optional but recommended)
# Create one: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Trading parameters
LEVERAGE=5            # 5x is safe for testing; max on SOLUSDTM is 75x
MARGIN_MODE=isolated  # isolated = capped loss per trade; cross = shared margin
CAPITAL=20.0          # USDT available for trading
TP_PCT=0.004          # 0.4% baseline TP (adapts at runtime via regime/vol)
