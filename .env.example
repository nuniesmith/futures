# ================================================================
# Futures Trader — Environment Config
# ================================================================
# Copy this to .env and fill in your real values.
# NEVER commit .env to git — it's in .gitignore.
#
# Repository: nuniesmith/futures
# ================================================================

# ─── KuCoin Futures API ──────────────────────────────────────────
# Generate at: KuCoin → Account → API Management
# Permissions required: Futures (trade + read)
KUCOIN_API_KEY=your_api_key_here
KUCOIN_API_SECRET=your_api_secret_here
KUCOIN_PASSPHRASE=your_passphrase_here

# ─── Redis ───────────────────────────────────────────────────────
# Used for PnL tracking, order history, candle cache, worker state.
# Must match the --requirepass value in docker-compose.yml.
REDIS_PASSWORD=change_me_to_a_strong_password
REDIS_URL=redis://futures-redis:6379/0

# ─── Discord Alerts (optional but recommended) ──────────────────
# Create one: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ─── Trading Mode ────────────────────────────────────────────────
# sim  = connect live WS feeds, track paper trades in Redis, NO real orders
# live = real trading — places actual orders via KuCoin API
TRADING_MODE=sim

# ─── Trading Parameters ─────────────────────────────────────────
CAPITAL=30.0              # Total USDT available for trading
MARGIN_MODE=isolated      # isolated (recommended) | cross

# ─── Timezone ────────────────────────────────────────────────────
# Used for daily P&L resets, log timestamps, Discord daily summaries.
# EDT = America/New_York (UTC-4 in summer, UTC-5 in winter)
TZ=America/New_York

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
