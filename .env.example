# ── KuCoin Futures API ─────────────────────────────────────────────
KUCOIN_API_KEY=your_api_key_here
KUCOIN_API_SECRET=your_api_secret_here
KUCOIN_PASSPHRASE=your_passphrase_here

# ── Discord Webhook (optional but recommended) ──────────────────────
# Create one at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Bot tuning ──────────────────────────────────────────────────────
LEVERAGE=5          # 5–75 (start low, increase when confident)
MARGIN_MODE=isolated  # isolated | cross
CAPITAL=20.0          # USD in your KuCoin Futures wallet
TP_PCT=0.004          # 0.4% take-profit per stack (static target)
